<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Colors -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="PrimaryDark">#3F1FA8</Color>
    <Color x:Key="PrimaryLight">#7B5CD9</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>
    <Color x:Key="SecondaryDark">#C8BEF0</Color>

    <!-- Semantic Colors -->
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Warning">#FFC107</Color>
    <Color x:Key="Danger">#F44336</Color>
    <Color x:Key="Info">#2196F3</Color>

    <!-- Segment Category Colors -->
    <Color x:Key="SegmentStart">#4CAF50</Color>
    <Color x:Key="SegmentSession">#9C27B0</Color>
    <Color x:Key="SegmentPriceCondition">#2196F3</Color>
    <Color x:Key="SegmentVwapCondition">#00BCD4</Color>
    <Color x:Key="SegmentIndicatorCondition">#FF9800</Color>
    <Color x:Key="SegmentOrder">#F44336</Color>
    <Color x:Key="SegmentRiskManagement">#FFC107</Color>
    <Color x:Key="SegmentPositionManagement">#795548</Color>
    <Color x:Key="SegmentOrderConfig">#607D8B</Color>

    <!-- Background Colors -->
    <Color x:Key="PageBackground">#1E1E1E</Color>
    <Color x:Key="CardBackground">#2D2D2D</Color>
    <Color x:Key="CanvasBackground">#252525</Color>
    <Color x:Key="ToolbarBackground">#333333</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#B0B0B0</Color>
    <Color x:Key="TextMuted">#707070</Color>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#404040</Color>
    <Color x:Key="BorderHighlight">#606060</Color>

    <!-- Drag & Drop Colors -->
    <Color x:Key="DragOverlay">#40512BD4</Color>
    <Color x:Key="DropTarget">#80512BD4</Color>

</ResourceDictionary>
