@page "/settings"
@using IdiotProof.Frontend.Services
@inject IBackendService BackendService
@inject IStrategyService StrategyService

<div class="settings-page">
    <h1 class="page-title mb-4">SETTINGS</h1>

    <!-- IBKR Connection -->
    <div class="settings-section">
        <div class="settings-section-title">IBKR Connection</div>

        <div class="settings-row">
            <label class="settings-label">Host:</label>
            <input type="text" @bind="IbkrHost" />
        </div>

        <div class="settings-row">
            <label class="settings-label">Port:</label>
            <input type="number" @bind="IbkrPort" />
        </div>

        <div class="settings-row">
            <label class="settings-label">Client ID:</label>
            <input type="number" @bind="IbkrClientId" />
        </div>

        <div class="settings-row">
            <label class="settings-label">Account Number:</label>
            <input type="text" @bind="AccountNumber" placeholder="e.g., U1234567" />
        </div>

        <div class="settings-hint">
            Port 7497 = TWS Paper, 7496 = TWS Live, 4002 = Gateway Paper, 4001 = Gateway Live
        </div>

        <div class="settings-actions">
            <button class="btn btn-secondary" @onclick="TestConnection">Test Connection</button>
            <button class="btn btn-primary" @onclick="SaveSettings">Save</button>
            <button class="btn btn-secondary" @onclick="ResetSettings">Reset</button>
        </div>
    </div>

    <!-- Backend Mode -->
    <div class="settings-section">
        <div class="settings-section-title">Backend Options</div>

        <div class="settings-row">
            <label class="settings-label">Silent Mode:</label>
            <div class="flex items-center gap-2">
                <input type="checkbox" @bind="SilentMode" />
                <span class="text-muted" style="font-size: 12px;">Only show *Blip* heartbeat in console</span>
            </div>
        </div>

        <div class="settings-row">
            <label class="settings-label">Auto-Start Trading:</label>
            <div class="flex items-center gap-2">
                <input type="checkbox" @bind="AutoStart" />
                <span class="text-muted" style="font-size: 12px;">Activate trading when backend starts</span>
            </div>
        </div>

        <div class="settings-row">
            <label class="settings-label">Heartbeat Interval:</label>
            <div class="flex items-center gap-2">
                <select @bind="HeartbeatMinutes">
                    <option value="1">1 minute</option>
                    <option value="5">5 minutes</option>
                    <option value="15">15 minutes</option>
                    <option value="30">30 minutes</option>
                    <option value="60">60 minutes</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Trading Controls -->
    <div class="settings-section">
        <div class="settings-section-title">Trading Controls</div>

        <div class="settings-row">
            <label class="settings-label">Trading Status:</label>
            <div class="flex items-center gap-2">
                <span class="status-dot @(BackendStatus?.IsTradingActive == true ? "success" : "warning")"></span>
                <span>@(BackendStatus?.IsTradingActive == true ? "Active" : "Paused")</span>
            </div>
        </div>

        <div class="settings-actions">
            @if (BackendStatus?.IsTradingActive == true)
            {
                <button class="btn btn-warning" @onclick="DeactivateTrading">Pause Trading</button>
            }
            else
            {
                <button class="btn btn-success" @onclick="ActivateTrading">Activate Trading</button>
            }
            <button class="btn btn-danger" @onclick="CancelAllOrders">Cancel All Orders</button>
            <button class="btn btn-secondary" @onclick="ReloadStrategies">Reload Strategies</button>
        </div>
    </div>

    <!-- Backend Status -->
    <div class="settings-section">
        <div class="settings-section-title">Backend Status</div>

        <div class="settings-row">
            <label class="settings-label">Backend Running:</label>
            <div class="flex items-center gap-2">
                <span class="status-dot @(BackendStatus?.IsRunning == true ? "success" : "danger")"></span>
                <span>@(BackendStatus?.IsRunning == true ? "Yes" : "No")</span>
            </div>
        </div>

        <div class="settings-row">
            <label class="settings-label">IBKR Connected:</label>
            <div class="flex items-center gap-2">
                <span class="status-dot @(BackendStatus?.IsConnectedToIbkr == true ? "success" : "danger")"></span>
                <span>@(BackendStatus?.IsConnectedToIbkr == true ? "Yes" : "No")</span>
            </div>
        </div>

        <div class="settings-row">
            <label class="settings-label">Trading Mode:</label>
            <div class="flex items-center gap-2">
                <span class="@(BackendStatus?.IsPaperTrading == true ? "text-success" : "text-danger")">
                    @(BackendStatus?.IsPaperTrading == true ? "PAPER" : "LIVE")
                </span>
            </div>
        </div>

        <div class="settings-row">
            <label class="settings-label">Active Strategies:</label>
            <span>@(BackendStatus?.ActiveStrategies ?? 0)</span>
        </div>

        <div class="settings-row">
            <label class="settings-label">Last Heartbeat:</label>
            <span>@(BackendStatus?.LastHeartbeat?.ToString("g") ?? "N/A")</span>
        </div>

        <div class="settings-actions">
            <button class="btn btn-secondary" @onclick="RefreshBackendStatus">Refresh Status</button>
        </div>
    </div>

    <!-- Appearance -->
    <div class="settings-section">
        <div class="settings-section-title">Appearance</div>

        <div class="settings-row">
            <label class="settings-label">Theme:</label>
            <select @bind="SelectedTheme" @bind:after="ApplyTheme">
                <option value="dark">Dark</option>
                <option value="light">Light</option>
                <option value="spring">Spring</option>
                <option value="summer">Summer</option>
                <option value="autumn">Autumn</option>
                <option value="winter">Winter</option>
            </select>
        </div>

        <div class="settings-row">
            <label class="settings-label">Show Strategy Notes:</label>
            <div class="flex items-center gap-2">
                <input type="checkbox" @bind="ShowNotes" @bind:after="SaveDisplaySettings" />
                <span class="text-muted" style="font-size: 12px;">Display notes in strategy canvas and logs</span>
            </div>
        </div>
    </div>

    <!-- Data Folders -->
    <div class="settings-section">
        <div class="settings-section-title">Data Folders</div>

        <div class="mb-2">
            <label class="settings-label">Strategies Folder:</label>
            <div class="text-muted" style="font-size: 12px; margin-top: 4px;">@StrategiesFolder</div>
        </div>

        <div class="settings-actions">
            <button class="btn btn-secondary" @onclick="OpenStrategiesFolder">Open Strategies Folder</button>
            <button class="btn btn-secondary" @onclick="OpenAppDataFolder">Open App Data</button>
        </div>
    </div>

    <!-- About -->
    <div class="settings-section">
        <div class="settings-section-title">About</div>
        <div>IdiotProof Strategy Builder</div>
        <div class="text-muted">Version 1.0.0</div>
        <div class="text-muted mt-2">A WYSIWYG interface for building IBKR trading strategies</div>
    </div>

    <div class="text-muted" style="text-align: center; margin-top: 24px;">@StatusMessage</div>
</div>

@code {
    // IBKR Connection
    private string IbkrHost = "127.0.0.1";
    private int IbkrPort = 7497;
    private int IbkrClientId = 1;
    private string AccountNumber = "";

    // Backend Options
    private bool SilentMode = false;
    private bool AutoStart = false;
    private int HeartbeatMinutes = 5;

    // Appearance
    private string SelectedTheme = "dark";
    private bool ShowNotes = true;

    // UI State
    private string StrategiesFolder = "";
    private string StatusMessage = "Ready";
    private BackendStatus? BackendStatus;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        LoadSettings();
        StrategiesFolder = StrategyService.StrategiesFolder;
        await RefreshBackendStatus();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyTheme();
        }
    }

    private void LoadSettings()
    {
        IbkrHost = Preferences.Get("IbkrHost", "127.0.0.1");
        IbkrPort = Preferences.Get("IbkrPort", 7497);
        IbkrClientId = Preferences.Get("IbkrClientId", 1);
        AccountNumber = Preferences.Get("AccountNumber", "");
        SilentMode = Preferences.Get("SilentMode", false);
        AutoStart = Preferences.Get("AutoStart", false);
        HeartbeatMinutes = Preferences.Get("HeartbeatMinutes", 5);
        SelectedTheme = Preferences.Get("Theme", "dark");
        ShowNotes = Preferences.Get("ShowNotes", true);
    }

    private void SaveSettings()
    {
        Preferences.Set("IbkrHost", IbkrHost);
        Preferences.Set("IbkrPort", IbkrPort);
        Preferences.Set("IbkrClientId", IbkrClientId);
        Preferences.Set("AccountNumber", AccountNumber);
        Preferences.Set("SilentMode", SilentMode);
        Preferences.Set("AutoStart", AutoStart);
        Preferences.Set("HeartbeatMinutes", HeartbeatMinutes);
        StatusMessage = "Settings saved";
    }

    private void SaveDisplaySettings()
    {
        Preferences.Set("ShowNotes", ShowNotes);
    }

    private async Task ApplyTheme()
    {
        Preferences.Set("Theme", SelectedTheme);
        await JS.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{SelectedTheme}')");
    }

    private void ResetSettings()
    {
        IbkrHost = "127.0.0.1";
        IbkrPort = 7497;
        IbkrClientId = 1;
        AccountNumber = "";
        SilentMode = false;
        AutoStart = false;
        HeartbeatMinutes = 5;
        SelectedTheme = "dark";
        ShowNotes = true;
        SaveSettings();
        StatusMessage = "Settings reset to defaults";
    }

    private async Task TestConnection()
    {
        StatusMessage = "Testing connection...";
        var connected = await BackendService.ConnectAsync();

        if (connected)
        {
            BackendStatus = await BackendService.GetStatusAsync();
            StatusMessage = BackendStatus.IsConnectedToIbkr 
                ? "✓ Connected to IBKR!" 
                : "Backend running, not connected to IBKR";
        }
        else
        {
            StatusMessage = "✗ Could not connect to backend";
        }
    }

    private async Task RefreshBackendStatus()
    {
        try
        {
            BackendStatus = await BackendService.GetStatusAsync();
            StatusMessage = "Status refreshed";
        }
        catch 
        {
            StatusMessage = "Could not get backend status";
        }
        StateHasChanged();
    }

    private async Task ActivateTrading()
    {
        StatusMessage = "Activating trading...";
        var result = await BackendService.ActivateTradingAsync();
        await RefreshBackendStatus();
        StatusMessage = result.Success ? "Trading activated" : (result.ErrorMessage ?? "Failed to activate trading");
    }

    private async Task DeactivateTrading()
    {
        StatusMessage = "Deactivating trading...";
        var result = await BackendService.DeactivateTradingAsync();
        await RefreshBackendStatus();
        StatusMessage = result.Success ? "Trading deactivated" : (result.ErrorMessage ?? "Failed to deactivate trading");
    }

    private async Task CancelAllOrders()
    {
        StatusMessage = "Cancelling all orders...";
        var result = await BackendService.CancelAllOrdersAsync();
        StatusMessage = result.Success ? (result.Message ?? "Orders cancelled") : (result.ErrorMessage ?? "Failed to cancel orders");
    }

    private async Task ReloadStrategies()
    {
        StatusMessage = "Reloading strategies...";
        try
        {
            await BackendService.ReloadStrategiesAsync();
            StatusMessage = "Strategies reloaded";
        }
        catch
        {
            StatusMessage = "Failed to reload strategies";
        }
    }

    private async Task OpenStrategiesFolder()
    {
        try
        {
            await Launcher.OpenAsync(new Uri($"file://{StrategiesFolder}"));
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }

    private async Task OpenAppDataFolder()
    {
        try
        {
            var appData = Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData);
            var folder = Path.Combine(appData, "IdiotProof");
            Directory.CreateDirectory(folder);
            await Launcher.OpenAsync(new Uri($"file://{folder}"));
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
}
