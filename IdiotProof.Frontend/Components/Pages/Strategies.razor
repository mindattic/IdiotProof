@page "/strategies"
@using IdiotProof.Frontend.Services
@using IdiotProof.Shared.Models
@inject IStrategyService StrategyService
@inject IBackendService BackendService
@inject NavigationManager Navigation

<div class="strategies-page">
    <div class="page-header">
        <div class="flex items-center gap-4">
            <h1 class="page-title">STRATEGIES</h1>
            <input type="date" @bind="SelectedDate" @bind:after="LoadStrategies" />
        </div>
        <div class="page-header-actions">
            <button class="btn btn-secondary" @onclick="LoadStrategies">Refresh</button>
            <button class="btn btn-secondary" @onclick="OpenFolder">Open Folder</button>
            <button class="btn btn-primary" @onclick="StartBackend" disabled="@(BackendStatus?.IsRunning == true)">
                @(BackendStatus?.IsRunning == true ? "Running" : "▶ Start")
            </button>
        </div>
    </div>

    @if (StrategyList.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-title">No strategies for this date</div>
            <div class="empty-state-text">Go to the Design tab to create a new strategy</div>
            <button class="btn btn-primary mt-4" @onclick="GoToDesign">Create Strategy</button>
        </div>
    }
    else
    {
        <!-- Quick Stats -->
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-value">@StrategyList.Count</div>
                <div class="stat-label">Total</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: var(--success);">@StrategyList.Count(s => s.Enabled)</div>
                <div class="stat-label">Enabled</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" style="color: var(--text-muted);">@StrategyList.Count(s => !s.Enabled)</div>
                <div class="stat-label">Disabled</div>
            </div>
        </div>

        @foreach (var strategy in StrategyList)
        {
            <div class="strategy-card @(strategy.Enabled ? "" : "disabled")">
                <div class="strategy-card-indicator" style="background-color: @(strategy.Enabled ? "var(--success)" : "var(--text-muted)")"></div>
                <div class="strategy-card-content">
                    <div class="strategy-card-header">
                        @if (RenamingStrategyId == strategy.Id)
                        {
                            <input type="text" 
                                   @bind="RenameValue" 
                                   @onkeydown="e => OnRenameKeyDown(e, strategy)"
                                   @onfocusout="() => CancelRename()"
                                   class="rename-input" 
                                   autofocus />
                            <button class="btn btn-sm btn-primary" @onclick="() => ConfirmRename(strategy)">✓</button>
                            <button class="btn btn-sm btn-secondary" @onclick="CancelRename">✕</button>
                        }
                        else
                        {
                            <span class="strategy-card-name" @ondblclick="() => StartRename(strategy)">@strategy.Name</span>
                            <span class="strategy-card-symbol">@strategy.Symbol</span>
                            <button class="btn-icon-tiny" @onclick="() => StartRename(strategy)" title="Rename">✏️</button>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(strategy.Description))
                    {
                        <div class="strategy-card-desc">@strategy.Description</div>
                    }
                    <div class="strategy-card-meta">
                        <span>@strategy.Segments.Count segments</span>
                        @if (!string.IsNullOrEmpty(strategy.Author))
                        {
                            <span>by @strategy.Author</span>
                        }
                        <span>Modified: @strategy.ModifiedAt.ToLocalTime().ToString("g")</span>
                    </div>
                </div>
                <div class="strategy-card-actions">
                    <button class="btn @(strategy.Enabled ? "btn-success" : "btn-secondary") btn-sm" @onclick="() => ToggleEnabled(strategy)">
                        @(strategy.Enabled ? "✓ Enabled" : "Disabled")
                    </button>
                    <button class="btn btn-secondary btn-sm" @onclick="() => EditStrategy(strategy)" title="Edit in Designer">
                        Edit
                    </button>
                    <button class="btn btn-secondary btn-sm btn-icon" @onclick="() => CopyCode(strategy)" title="Copy Code">📋</button>
                    <button class="btn btn-secondary btn-sm btn-icon" @onclick="() => Duplicate(strategy)" title="Clone">📄</button>
                    <button class="btn btn-danger btn-sm btn-icon" @onclick="() => ConfirmDelete(strategy)" title="Delete">🗑️</button>
                </div>
            </div>
        }
    }

    <!-- Delete Confirmation Modal -->
    @if (DeletingStrategy != null)
    {
        <div class="modal-overlay" @onclick="() => DeletingStrategy = null">
            <div class="modal-dialog" @onclick:stopPropagation="true">
                <div class="modal-title">Delete Strategy?</div>
                <div class="modal-content">
                    Are you sure you want to delete "<strong>@DeletingStrategy.Name</strong>"?
                    <br />This action cannot be undone.
                </div>
                <div class="modal-actions">
                    <button class="btn btn-secondary" @onclick="() => DeletingStrategy = null">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteConfirmed">Delete</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<StrategyDefinition> StrategyList = new();
    private DateTime SelectedDate = DateTime.Today;
    private string StatusMessage = "Ready";
    private BackendStatus? BackendStatus;

    // Rename state
    private Guid? RenamingStrategyId;
    private string RenameValue = "";

    // Delete confirmation
    private StrategyDefinition? DeletingStrategy;

    protected override async Task OnInitializedAsync()
    {
        await LoadStrategies();
        await RefreshBackendStatus();
    }

    private async Task LoadStrategies()
    {
        try
        {
            var collection = await StrategyService.GetCollectionAsync(DateOnly.FromDateTime(SelectedDate));
            StrategyList = collection.Strategies.OrderBy(s => s.Name).ToList();
            StatusMessage = $"Loaded {StrategyList.Count} strategies for {SelectedDate:MMM dd, yyyy}";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }

    private async Task RefreshBackendStatus()
    {
        try
        {
            BackendStatus = await BackendService.GetStatusAsync();
        }
        catch { }
    }

    private async Task ToggleEnabled(StrategyDefinition strategy)
    {
        strategy.Enabled = !strategy.Enabled;
        await StrategyService.SaveStrategyAsync(strategy, DateOnly.FromDateTime(SelectedDate));
        StatusMessage = $"Strategy {(strategy.Enabled ? "enabled" : "disabled")}: {strategy.Name}";
    }

    private void StartRename(StrategyDefinition strategy)
    {
        RenamingStrategyId = strategy.Id;
        RenameValue = strategy.Name;
    }

    private void CancelRename()
    {
        RenamingStrategyId = null;
        RenameValue = "";
    }

    private async Task ConfirmRename(StrategyDefinition strategy)
    {
        if (string.IsNullOrWhiteSpace(RenameValue))
        {
            StatusMessage = "Name cannot be empty";
            return;
        }

        var oldName = strategy.Name;
        await StrategyService.RenameStrategyAsync(strategy, RenameValue.Trim(), DateOnly.FromDateTime(SelectedDate));
        await LoadStrategies();
        RenamingStrategyId = null;
        RenameValue = "";
        StatusMessage = $"Renamed: {oldName} → {strategy.Name}";
    }

    private async Task OnRenameKeyDown(KeyboardEventArgs e, StrategyDefinition strategy)
    {
        if (e.Key == "Enter")
        {
            await ConfirmRename(strategy);
        }
        else if (e.Key == "Escape")
        {
            CancelRename();
        }
    }

    private async Task CopyCode(StrategyDefinition strategy)
    {
        var code = StrategyService.ExportToCode(strategy);
        await Clipboard.SetTextAsync(code);
        StatusMessage = $"Code copied for: {strategy.Name}";
    }

    private async Task Duplicate(StrategyDefinition strategy)
    {
        var clone = await StrategyService.CloneStrategyAsync(strategy, DateOnly.FromDateTime(SelectedDate));
        await LoadStrategies();
        StatusMessage = $"Cloned: {strategy.Name} → {clone.Name}";
    }

    private void ConfirmDelete(StrategyDefinition strategy)
    {
        DeletingStrategy = strategy;
    }

    private async Task DeleteConfirmed()
    {
        if (DeletingStrategy != null)
        {
            var name = DeletingStrategy.Name;
            await StrategyService.DeleteStrategyAsync(DeletingStrategy, DateOnly.FromDateTime(SelectedDate));
            DeletingStrategy = null;
            await LoadStrategies();
            StatusMessage = $"Deleted: {name}";
        }
    }

    private void EditStrategy(StrategyDefinition strategy)
    {
        // Navigate to design page with strategy ID
        Navigation.NavigateTo($"/?edit={strategy.Id}");
    }

    private void GoToDesign()
    {
        Navigation.NavigateTo("/");
    }

    private async Task OpenFolder()
    {
        try
        {
            await Launcher.OpenAsync(new Uri($"file://{StrategyService.StrategiesFolder}"));
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }

    private async Task StartBackend()
    {
        try
        {
            await BackendService.ReloadStrategiesAsync();
            await RefreshBackendStatus();
            StatusMessage = "Backend strategies reloaded";
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error: {ex.Message}";
        }
    }
}
