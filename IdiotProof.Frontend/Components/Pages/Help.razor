@page "/help"
@using Markdig
@inject IJSRuntime JS

<div class="help-page">
    <div class="page-header">
        <h1 class="page-title">HELP & DOCUMENTATION</h1>
    </div>

    <div class="markdown-container">
        @((MarkupString)_htmlContent)
    </div>
</div>

@code {
    private string _htmlContent = "";
    private string _markdownContent = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadReadme();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize syntax highlighting after render
            await JS.InvokeVoidAsync("initializeSyntaxHighlighting");
        }
    }

    private async Task LoadReadme()
    {
        try
        {
            // Load README.md from the app's base directory
            var readmePath = GetReadmePath();
            
            if (File.Exists(readmePath))
            {
                _markdownContent = await File.ReadAllTextAsync(readmePath);
            }
            else
            {
                // Try alternative paths
                var altPaths = new[]
                {
                    Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "..", "..", "README.md"),
                    Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "..", "README.md"),
                    Path.Combine(Environment.CurrentDirectory, "README.md"),
                    Path.Combine(Environment.CurrentDirectory, "..", "README.md"),
                    @"D:\Projects\IdiotProof\README.md" // Fallback to known path
                };

                foreach (var path in altPaths)
                {
                    var fullPath = Path.GetFullPath(path);
                    if (File.Exists(fullPath))
                    {
                        _markdownContent = await File.ReadAllTextAsync(fullPath);
                        break;
                    }
                }
            }

            if (string.IsNullOrEmpty(_markdownContent))
            {
                _markdownContent = "# README Not Found\n\nCould not locate the README.md file.";
            }

            // Convert markdown to HTML using Markdig
            var pipeline = new MarkdownPipelineBuilder()
                .UseAdvancedExtensions()
                .UseAutoIdentifiers()
                .UseAutoLinks()
                .UseTaskLists()
                .UseEmojiAndSmiley()
                .Build();

            _htmlContent = Markdown.ToHtml(_markdownContent, pipeline);
        }
        catch (Exception ex)
        {
            _htmlContent = $"<div class='error'>Error loading documentation: {ex.Message}</div>";
        }
    }

    private string GetReadmePath()
    {
        // Start from app directory and work up to find README.md
        var baseDir = AppContext.BaseDirectory;
        var currentDir = new DirectoryInfo(baseDir);
        
        while (currentDir != null)
        {
            var readmePath = Path.Combine(currentDir.FullName, "README.md");
            if (File.Exists(readmePath))
            {
                return readmePath;
            }
            currentDir = currentDir.Parent;
        }
        
        return Path.Combine(baseDir, "README.md");
    }
}
