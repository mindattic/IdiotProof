@page "/progress"
@using IdiotProof.Frontend.Services
@using IdiotProof.Shared.Models
@using Microsoft.JSInterop
@inject IBackendService BackendService
@inject IJSRuntime JS
@implements IDisposable

<div class="progress-page">
    <div class="page-header">
        <h1 class="page-title">PROGRESS</h1>
        <div class="page-header-actions">
            <button class="btn btn-secondary" @onclick="ClearConsole">Clear</button>
            <button class="btn btn-secondary" @onclick="CopyToClipboard">Copy All</button>
            <label class="toggle-label">
                <input type="checkbox" @bind="AutoScroll" />
                Auto-scroll
            </label>
            <label class="toggle-label">
                <input type="checkbox" @bind="WrapLines" />
                Wrap lines
            </label>
        </div>
    </div>

    <!-- Console Output Area -->
    <div class="console-container @(WrapLines ? "wrap-lines" : "")">
        <div class="console-content" @ref="ConsoleElement">
            @foreach (var line in ConsoleLines)
            {
                <div class="console-line @GetLineClass(line)">@line</div>
            }
            @if (ConsoleLines.Count == 0)
            {
                <div class="console-empty">
                    @if (!BackendService.IsConnected)
                    {
                        <span>Connect to backend to see console output</span>
                    }
                    else
                    {
                        <span>Waiting for output...</span>
                    }
                </div>
            }
        </div>
    </div>

    <div class="progress-footer">
        <span>Lines: @ConsoleLines.Count</span>
    </div>
</div>

@code {
    private List<string> ConsoleLines = [];
    private bool AutoScroll = true;
    private bool WrapLines = false;
    private ElementReference ConsoleElement;
    private bool _shouldScroll = false;

    protected override void OnInitialized()
    {
        BackendService.ConsoleOutputReceived += OnConsoleOutput;
        LoadExistingBuffer();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldScroll && AutoScroll)
        {
            _shouldScroll = false;
            await ScrollToBottom();
        }
    }

    private void LoadExistingBuffer()
    {
        var buffer = BackendService.GetConsoleBuffer();
        if (!string.IsNullOrEmpty(buffer))
        {
            ConsoleLines = buffer.Split('\n', StringSplitOptions.RemoveEmptyEntries).ToList();
            _shouldScroll = true;
            StateHasChanged();
        }
    }

    private void OnConsoleOutput(object? sender, ConsoleOutputMessage output)
    {
        // Split output into lines and add
        var lines = output.Text.Split('\n', StringSplitOptions.RemoveEmptyEntries);
        foreach (var line in lines)
        {
            ConsoleLines.Add(line);
        }

        // Trim if too many lines
        const int maxLines = 5000;
        if (ConsoleLines.Count > maxLines)
        {
            ConsoleLines = ConsoleLines.Skip(ConsoleLines.Count - maxLines + 500).ToList();
            ConsoleLines.Insert(0, "[... earlier output trimmed ...]");
        }

        _shouldScroll = AutoScroll;
        InvokeAsync(StateHasChanged);
    }

    private void ClearConsole()
    {
        ConsoleLines.Clear();
    }

    private async Task CopyToClipboard()
    {
        var text = string.Join("\n", ConsoleLines);
        try
        {
            await Clipboard.SetTextAsync(text);
        }
        catch
        {
            // Clipboard copy failed silently
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", ConsoleElement);
        }
        catch { }
    }

    private string GetLineClass(string line)
    {
        if (line.Contains("ERROR", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("EXCEPTION", StringComparison.OrdinalIgnoreCase))
        {
            return "line-error";
        }
        if (line.Contains("WARNING", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("WARN", StringComparison.OrdinalIgnoreCase))
        {
            return "line-warning";
        }
        if (line.Contains("SUCCESS", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("FILLED", StringComparison.OrdinalIgnoreCase) ||
            line.Contains("CONNECTED", StringComparison.OrdinalIgnoreCase))
        {
            return "line-success";
        }
        if (line.StartsWith(">>>") || line.Contains("BUY") || line.Contains("SELL"))
        {
            return "line-highlight";
        }
        if (line.StartsWith("[") || line.Contains("DEBUG"))
        {
            return "line-debug";
        }
        return "";
    }

    public void Dispose()
    {
        BackendService.ConsoleOutputReceived -= OnConsoleOutput;
    }
}
