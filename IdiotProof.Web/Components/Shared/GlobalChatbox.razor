@* Global Chatbox Component - AI Assistant Available on All Screens *@
@using IdiotProof.Web.Services.AI
@inject AiAdvisorService AiService
@inject IJSRuntime JS

<div class="global-chatbox @(IsMinimized ? "minimized" : "expanded")" @onclick:stopPropagation="true">
    <div class="chatbox-header" @onclick="ToggleMinimize" role="button" tabindex="0" aria-expanded="@(!IsMinimized)" aria-label="Toggle AI Assistant">
        <div class="chatbox-toggle">🤖</div>
        <span class="chatbox-title">AI Assistant</span>
        @if (!string.IsNullOrEmpty(CurrentSymbol))
        {
            <span class="chatbox-status">
                Watching: <span style="color: #58a6ff; font-weight: 600;">@CurrentSymbol</span>
            </span>
        }
        <span class="chatbox-expand-hint">@(IsMinimized ? "Click to expand" : "")</span>
        <button class="chatbox-minimize-btn" @onclick:stopPropagation="true" @onclick="ToggleMinimize" aria-label="@(IsMinimized ? "Expand" : "Collapse")">
            @(IsMinimized ? "▲" : "▼")
        </button>
    </div>

    @if (!IsMinimized)
    {
        <div class="chatbox-body">
            <div class="chatbox-messages" @ref="messagesRef">
                @if (!Messages.Any())
                {
                    <div class="chat-message assistant">
                        <div class="chat-bubble">
                            👋 Hi! I'm your AI trading assistant. Ask me about strategies, market analysis, or click any log entry to discuss it.
                        </div>
                    </div>
                }
                
                @foreach (var msg in Messages)
                {
                    <div class="chat-message @msg.Role">
                        <div class="chat-bubble">
                            @((MarkupString)FormatMessage(msg.Content))
                        </div>
                        <div class="chat-timestamp">@msg.Timestamp.ToString("HH:mm")</div>
                    </div>
                }
                
                @if (IsLoading)
                {
                    <div class="chat-message assistant">
                        <div class="chat-bubble">
                            <div class="typing-indicator">
                                <div class="typing-dot"></div>
                                <div class="typing-dot"></div>
                                <div class="typing-dot"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="chatbox-quick-actions">
                <button class="quick-action-btn" @onclick="@(() => SendQuickAction(QuickActionMarket))">📊 Market Sentiment</button>
                <button class="quick-action-btn" @onclick="@(() => SendQuickAction(QuickActionTrade))">💡 Trade Advice</button>
                <button class="quick-action-btn" @onclick="@(() => SendQuickAction(QuickActionStrategy))">📋 Explain Strategy</button>
                <button class="quick-action-btn" @onclick="@(() => SendQuickAction(QuickActionRisk))">⚠️ Risk Analysis</button>
            </div>

            <div class="chatbox-input-area">
                @if (!string.IsNullOrEmpty(CurrentSymbol))
                {
                    <div class="chatbox-context">
                        <span>📈</span>
                        <span class="chatbox-context-symbol">@CurrentSymbol</span>
                    </div>
                }

                <textarea class="chatbox-textarea" 
                          placeholder="Ask about trading, strategies, or market analysis..."
                          @bind="InputText"
                          @onkeydown="HandleKeyDown"
                          rows="1"></textarea>
                
                <button class="chatbox-send-btn @(IsLoading ? "loading" : "")" 
                        @onclick="SendMessage" 
                        disabled="@(IsLoading || string.IsNullOrWhiteSpace(InputText))">
                    @(IsLoading ? "⏳" : "➤")
                </button>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string? CurrentSymbol { get; set; }

    private ElementReference messagesRef;
    private List<ChatMessage> Messages { get; set; } = [];
    private string InputText { get; set; } = "";
    private bool IsMinimized { get; set; } = true;
    private bool IsLoading { get; set; }

    // Quick action strings
    private const string QuickActionMarket = "What's the market sentiment right now?";
    private const string QuickActionStrategy = "Explain my current strategy";
    private const string QuickActionRisk = "What are the risks?";
    private string QuickActionTrade => $"Should I buy or sell {CurrentSymbol ?? "NVDA"}?";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Register global function for log entries to call
            await JS.InvokeVoidAsync("eval", @"
                window.IdiotProof = window.IdiotProof || {};
                window.IdiotProof.copyToChat = function(text) {
                    const event = new CustomEvent('chatbox-input', { detail: text });
                    document.dispatchEvent(event);
                };
            ");

            // Listen for input events
            await JS.InvokeVoidAsync("eval", @"
                document.addEventListener('chatbox-input', function(e) {
                    DotNet.invokeMethodAsync('IdiotProof.Web', 'SetChatInput', e.detail);
                });
            ");
        }

        if (!IsMinimized && Messages.Any())
        {
            await ScrollToBottom();
        }
    }

    [JSInvokable]
    public static Task SetChatInput(string text)
    {
        // This would need a more sophisticated approach with a service
        // For now, the basic flow works via JS events
        return Task.CompletedTask;
    }
    
    public void SetInput(string text)
    {
        InputText = text;
        IsMinimized = false;
        StateHasChanged();
    }
    
    private void ToggleMinimize()
    {
        IsMinimized = !IsMinimized;
    }
    
    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }
    
    private async Task SendQuickAction(string action)
    {
        InputText = action;
        await SendMessage();
    }
    
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(InputText) || IsLoading)
            return;
        
        var userMessage = InputText.Trim();
        InputText = "";
        
        // Add user message
        Messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userMessage,
            Timestamp = DateTime.Now
        });
        
        IsLoading = true;
        StateHasChanged();
        await ScrollToBottom();
        
        try
        {
            // Call AI service
            var response = await AiService.GetAdviceAsync(userMessage, CurrentSymbol);
            
            Messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = response,
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            Messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"Sorry, I encountered an error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }
    
    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", 
                "document.querySelector('.chatbox-messages')?.scrollTo({top: document.querySelector('.chatbox-messages')?.scrollHeight, behavior: 'smooth'})");
        }
        catch { }
    }
    
    private static string FormatMessage(string content)
    {
        // Basic markdown-like formatting
        content = System.Net.WebUtility.HtmlEncode(content);
        
        // Bold
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        
        // Code
        content = System.Text.RegularExpressions.Regex.Replace(
            content, @"`(.+?)`", "<code style='background:#21262d;padding:2px 4px;border-radius:3px;'>$1</code>");
        
        // Line breaks
        content = content.Replace("\n", "<br/>");
        
        return content;
    }
    
    private sealed class ChatMessage
    {
        public string Role { get; set; } = "";
        public string Content { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
