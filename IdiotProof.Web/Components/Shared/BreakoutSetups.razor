@* ============================================================================
   BreakoutSetups.razor - Component displaying active breakout-pullback setups
   ============================================================================
   Shows setups generated by the PremarketSetupScanner with:
   - Real-time state tracking (Watching → Triggered → Confirmed)
   - One-click IdiotScript generation
   - Strategy cards in the pro trader format
   ============================================================================ *@

@using IdiotProof.Scripting
@using IdiotProof.Web.Services.MarketScanner
@using Microsoft.AspNetCore.SignalR.Client
@inject BreakoutSetupService SetupService
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="breakout-setups-panel" data-meta="Breakout-pullback setups scanned from gappers. Follow the state machine: Watching → Triggered → Confirmed → Entry">
    <div class="panel-header">
        <h3>
            <span class="icon">📊</span>
            Breakout-Pullback Setups
        </h3>
        <div class="header-actions">
            <span class="setup-count" data-meta="@_setups.Count active setups being monitored">@_setups.Count active</span>
            <button class="btn-refresh" @onclick="RefreshSetups" 
                    title="Rescan gappers for new breakout-pullback setups"
                    data-tooltip="Rescan all gappers for qualified breakout-pullback setups">
                🔄
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <div class="status-message @(_statusMessage.StartsWith("✅") ? "success" : _statusMessage.StartsWith("❌") ? "error" : "info")">
            @_statusMessage
        </div>
    }

    @if (_setups.Count == 0)
    {
        <div class="no-setups" data-meta="No setups found. Setups require: 3%+ gap, 1.5x volume, $0.30-$25 price range">
            <p>No qualified setups found.</p>
            <p class="hint">Setups require: 3%+ gap, 1.5x volume, $0.30-$25 price range</p>
        </div>
    }
    else
    {
        <div class="setups-list">
            @foreach (var setup in _setups)
            {
                var analysisText = $"{setup.Symbol}: {setup.Bias}. " +
                                  $"State: {setup.State}. " +
                                  $"Trigger: ${setup.TriggerPrice:F2}, Support: ${setup.SupportPrice:F2}, Stop: ${setup.InvalidationPrice:F2}. " +
                                  $"Targets: {string.Join(", ", setup.Targets.Select(t => $"{t.Label}=${t.Price:F2}"))}. " +
                                  $"R:R {setup.RiskRewardRatio:F1}:1, Confidence {setup.ConfidenceScore}%. " +
                                  $"{(setup.State == SetupState.Confirmed ? "READY TO ENTER!" : setup.State == SetupState.Watching ? "Waiting for breakout trigger." : "Monitoring pullback.")}";

                <div class="setup-card @GetStateClass(setup.State)" data-analysis="@analysisText">
                    <div class="setup-header">
                        <span class="symbol">@setup.Symbol</span>
                        <span class="state-badge @GetStateClass(setup.State)" 
                              data-meta="@GetStateDescription(setup.State)">@GetStateLabel(setup.State)</span>
                        <span class="confidence conf-@GetConfidenceClass(setup.ConfidenceScore)"
                              data-meta="Confidence @setup.ConfidenceScore%: @(setup.ConfidenceScore >= 80 ? "High probability" : setup.ConfidenceScore >= 60 ? "Good setup" : "Moderate")">
                            @setup.ConfidenceScore%
                        </span>
                    </div>

                    <div class="setup-bias" data-meta="@setup.Bias - @setup.Pattern">@setup.Bias</div>

                    <div class="setup-levels">
                        <div class="level" data-meta="Trigger level: Break above this price activates the setup">
                            <span class="label">Trigger:</span>
                            <span class="value trigger">$@setup.TriggerPrice.ToString("F2")</span>
                        </div>
                        <div class="level" data-meta="Support level: Must hold this after breakout for confirmation">
                            <span class="label">Support:</span>
                            <span class="value support">$@setup.SupportPrice.ToString("F2")</span>
                        </div>
                        <div class="level" data-meta="Invalidation: Below this price, the pattern fails - NO TRADE">
                            <span class="label">Stop:</span>
                            <span class="value stop">$@setup.InvalidationPrice.ToString("F2")</span>
                        </div>
                    </div>

                    <div class="setup-targets">
                        @foreach (var target in setup.Targets)
                        {
                            var pct = (target.Price - setup.TriggerPrice) / setup.TriggerPrice * 100;
                            <span class="target @(target.IsHit ? "hit" : "")"
                                  data-meta="@target.Label: $@target.Price.ToString("F2") (@pct.ToString("+0.0")%) - @(target.IsHit ? "HIT ✓" : $"Sell {target.PercentToSell}%")">
                                @target.Label: $@target.Price.ToString("F2") (@pct.ToString("+0.0")%)
                            </span>
                        }
                    </div>

                    <div class="setup-metrics">
                        <span class="gap @(setup.GapPercent > 0 ? "up" : "down")"
                              data-meta="Gap from previous close: @setup.GapPercent.ToString("+0.0;-0.0")%">
                            Gap: @setup.GapPercent.ToString("+0.0;-0.0")%
                        </span>
                        <span class="volume">Vol: @setup.VolumeRatio.ToString("0.0")x</span>
                        <span class="rr">R:R @setup.RiskRewardRatio.ToString("0.0"):1</span>
                    </div>
                    
                    <div class="setup-actions">
                        @if (setup.State == SetupState.Confirmed)
                        {
                            <button class="btn-execute" @onclick="() => ExecuteSetup(setup)">
                                ⚡ Execute Trade
                            </button>
                        }
                        <button class="btn-script" @onclick="() => ShowScript(setup)">
                            📝 IdiotScript
                        </button>
                        <button class="btn-card" @onclick="() => ShowCard(setup)">
                            📋 Card
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    
    @if (_showScriptModal)
    {
        <div class="modal-overlay" @onclick="CloseModals">
            <div class="modal-content" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>IdiotScript - @_selectedSetup?.Symbol</h4>
                    <button class="btn-close" @onclick="CloseModals">×</button>
                </div>
                <pre class="script-content">@_selectedSetup?.ToIdiotScript()</pre>
                <div class="modal-actions">
                    <button class="btn-copy" @onclick="CopyScript">📋 Copy</button>
                </div>
            </div>
        </div>
    }
    
    @if (_showCardModal)
    {
        <div class="modal-overlay" @onclick="CloseModals">
            <div class="modal-content card-modal" @onclick:stopPropagation="true">
                <div class="modal-header">
                    <h4>Strategy Card - @_selectedSetup?.Symbol</h4>
                    <button class="btn-close" @onclick="CloseModals">×</button>
                </div>
                <pre class="card-content">@_selectedSetup?.ToStrategyCard()</pre>
            </div>
        </div>
    }
</div>

@code {
    private List<BreakoutSetup> _setups = new();
    private bool _showScriptModal = false;
    private bool _showCardModal = false;
    private BreakoutSetup? _selectedSetup;
    private HubConnection? _hubConnection;
    private bool _isExecuting = false;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        SetupService.OnSetupsUpdated += HandleSetupsUpdated;
        SetupService.OnSetupStateChanged += HandleStateChanged;
        _setups = SetupService.GetActiveSetups().ToList();

        // Connect to TradingHub for trade execution
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/hubs/trading"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string>("ExecutionQueued", (symbol) =>
        {
            _statusMessage = $"✅ {symbol} trade queued for execution";
            InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<string>("ExecutionError", (error) =>
        {
            _statusMessage = $"❌ {error}";
            InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR connection failed: {ex.Message}");
        }
    }
    
    private void HandleSetupsUpdated(IReadOnlyList<BreakoutSetup> setups)
    {
        _setups = setups.ToList();
        InvokeAsync(StateHasChanged);
    }
    
    private void HandleStateChanged(BreakoutSetup setup, SetupState newState)
    {
        // Refresh the list
        _setups = SetupService.GetActiveSetups().ToList();
        InvokeAsync(StateHasChanged);
    }
    
    private void RefreshSetups()
    {
        SetupService.RescanGappers();
    }
    
    private void ShowScript(BreakoutSetup setup)
    {
        _selectedSetup = setup;
        _showScriptModal = true;
    }
    
    private void ShowCard(BreakoutSetup setup)
    {
        _selectedSetup = setup;
        _showCardModal = true;
    }
    
    private void CloseModals()
    {
        _showScriptModal = false;
        _showCardModal = false;
        _selectedSetup = null;
    }
    
    private async Task CopyScript()
    {
        if (_selectedSetup == null) return;

        try
        {
            var script = _selectedSetup.ToIdiotScript();
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", script);
            _statusMessage = "📋 Script copied to clipboard!";
            StateHasChanged();

            // Clear message after 3 seconds
            await Task.Delay(3000);
            _statusMessage = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _statusMessage = $"❌ Copy failed: {ex.Message}";
            StateHasChanged();
        }
    }

    private async Task ExecuteSetup(BreakoutSetup setup)
    {
        if (_isExecuting || _hubConnection?.State != HubConnectionState.Connected) 
        {
            _statusMessage = "⚠️ Not connected to trading hub";
            return;
        }

        _isExecuting = true;
        _statusMessage = $"⏳ Executing {setup.Symbol}...";
        StateHasChanged();

        try
        {
            // Send to TradingHub for execution
            await _hubConnection.InvokeAsync("ExecuteBreakoutSetup", setup.Symbol);

            // Mark the setup as entered
            SetupService.MarkAsEntered(setup.Symbol, setup.CurrentPrice > 0 ? setup.CurrentPrice : setup.TriggerPrice);

            _statusMessage = $"✅ {setup.Symbol} trade submitted!";
        }
        catch (Exception ex)
        {
            _statusMessage = $"❌ Execution failed: {ex.Message}";
        }
        finally
        {
            _isExecuting = false;
            StateHasChanged();
        }
    }
    
    private string GetStateClass(SetupState state) => state switch
    {
        SetupState.Watching => "state-watching",
        SetupState.Triggered => "state-triggered",
        SetupState.PullingBack => "state-pullback",
        SetupState.Confirmed => "state-confirmed",
        SetupState.Entered => "state-entered",
        SetupState.Scaling => "state-scaling",
        SetupState.Completed => "state-completed",
        SetupState.Invalidated => "state-invalidated",
        _ => ""
    };
    
    private string GetStateLabel(SetupState state) => state switch
    {
        SetupState.Watching => "👀 WATCHING",
        SetupState.Triggered => "🚀 TRIGGERED",
        SetupState.PullingBack => "↩️ PULLBACK",
        SetupState.Confirmed => "✅ CONFIRMED",
        SetupState.Entered => "📈 ACTIVE",
        SetupState.Scaling => "💰 SCALING",
        SetupState.Completed => "🎯 DONE",
        SetupState.Invalidated => "❌ INVALID",
        _ => state.ToString()
    };

    private string GetStateDescription(SetupState state) => state switch
    {
        SetupState.Watching => "Waiting for price to break above trigger level",
        SetupState.Triggered => "Breakout occurred! Waiting for pullback to confirm support",
        SetupState.PullingBack => "Price pulling back - watching if it holds support/VWAP",
        SetupState.Confirmed => "CONFIRMED! Setup is ready for entry. Pullback held support.",
        SetupState.Entered => "Position active - monitoring targets and stop loss",
        SetupState.Scaling => "Hitting targets, scaling out of position",
        SetupState.Completed => "Trade completed - all targets hit",
        SetupState.Invalidated => "Setup failed - price broke below support (NO TRADE)",
        _ => state.ToString()
    };
    
    private string GetConfidenceClass(int score) => score switch
    {
        >= 85 => "excellent",
        >= 70 => "good",
        >= 55 => "fair",
        _ => "low"
    };
    
    public async ValueTask DisposeAsync()
    {
        SetupService.OnSetupsUpdated -= HandleSetupsUpdated;
        SetupService.OnSetupStateChanged -= HandleStateChanged;

        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
