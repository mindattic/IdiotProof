@using IdiotProof.Web.Services.AI
@using System.Text.Json
@inject AiAdvisorService AiAdvisor
@inject IJSRuntime JS
@inject NavigationManager Navigation

@* Floating Screenshot Button - Always Visible *@
<button class="ai-fab @(_isAnalyzing ? "analyzing" : "")" 
        @onclick="CaptureAndAnalyze" 
        disabled="@_isAnalyzing"
        title="📸 Take a picture and explain this to me"
        data-tooltip="Capture screen and get AI analysis of what you're seeing">
    @if (_isAnalyzing)
    {
        <span class="fab-spinner">⟳</span>
    }
    else
    {
        <span class="fab-icon">📸</span>
    }
    <span class="fab-label">Explain This</span>
</button>

<div class="ai-advisor-container @(_isExpanded ? "expanded" : "collapsed")">
    <div class="ai-advisor-header" @onclick="ToggleExpanded">
        <div class="header-left">
            <span class="ai-icon">🤖</span>
            <span class="ai-title">AI Advisor</span>
            @if (_isAnalyzing)
            {
                <span class="analyzing-badge">Analyzing...</span>
            }
        </div>
        <div class="header-right">
            <button class="btn-capture" @onclick="CaptureAndAnalyze" @onclick:stopPropagation="true" 
                    disabled="@_isAnalyzing" 
                    title="Capture & Analyze Screen"
                    data-tooltip="Take a screenshot and get AI-powered analysis">
                📸
            </button>
            <button class="btn-context" @onclick="ExtractAndShowContext" @onclick:stopPropagation="true"
                    disabled="@_isAnalyzing"
                    title="Extract Page Context"
                    data-tooltip="Show all data-analysis and data-meta information on this page">
                📋
            </button>
            <button class="btn-toggle" title="@(_isExpanded ? "Minimize" : "Expand")">
                @(_isExpanded ? "▼" : "▲")
            </button>
        </div>
    </div>

    @if (_isExpanded)
    {
        <div class="ai-advisor-body">
            <div class="quick-actions">
                <button class="quick-action" @onclick='() => AskQuickQuestion("What should I focus on right now?")'
                        data-tooltip="Get AI advice on current priorities">
                    🎯 What now?
                </button>
                <button class="quick-action" @onclick='() => AskQuickQuestion("Explain the current market conditions")'
                        data-tooltip="Get market sentiment analysis">
                    📊 Market
                </button>
                <button class="quick-action" @onclick='() => AskQuickQuestion("What are the risks I should watch for?")'
                        data-tooltip="Get risk assessment">
                    ⚠️ Risks
                </button>
                <button class="quick-action" @onclick="CaptureAndAnalyze"
                        data-tooltip="Take a picture and explain this to me">
                    📸 Explain This
                </button>
            </div>

            <div class="messages-container" @ref="_messagesContainer">
                @if (_messages.Count == 0)
                {
                    <div class="empty-state">
                        <p>👋 Hi! I'm your AI trading advisor.</p>
                        <p>📸 Click <strong>"Explain This"</strong> anytime to capture the screen and I'll analyze what I see.</p>
                        <p>💡 I can see all the data on your screen including charts, indicators, and statistics.</p>
                        <div class="empty-state-features">
                            <div class="feature">
                                <span class="feature-icon">📊</span>
                                <span class="feature-text">Chart analysis</span>
                            </div>
                            <div class="feature">
                                <span class="feature-icon">📈</span>
                                <span class="feature-text">Pattern detection</span>
                            </div>
                            <div class="feature">
                                <span class="feature-icon">⚠️</span>
                                <span class="feature-text">Risk warnings</span>
                            </div>
                            <div class="feature">
                                <span class="feature-icon">💡</span>
                                <span class="feature-text">Trade ideas</span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var message in _messages)
                    {
                        <div class="message @(message.IsUser ? "user" : "ai")">
                            <div class="message-header">
                                <span class="sender">@(message.IsUser ? "You" : "AI Advisor")</span>
                                <span class="time">@message.Timestamp.ToString("HH:mm")</span>
                            </div>
                            <div class="message-content">
                                @if (message.HasImage)
                                {
                                    <div class="screenshot-preview">
                                        <img src="@message.ImageData" alt="Screenshot" />
                                    </div>
                                }
                                <div class="message-text">@((MarkupString)FormatMessage(message.Text))</div>
                            </div>
                        </div>
                    }
                }
            </div>
            
            <div class="input-container">
                <input type="text" 
                       @bind="_userInput" 
                       @bind:event="oninput"
                       @onkeypress="HandleKeyPress"
                       placeholder="Ask about your trades..." 
                       disabled="@_isAnalyzing" />
                <button class="btn-send" @onclick="SendMessage" disabled="@(string.IsNullOrWhiteSpace(_userInput) || _isAnalyzing)">
                    ➤
                </button>
            </div>
        </div>
    }
</div>

@code {
    private bool _isExpanded = false;
    private bool _isAnalyzing = false;
    private string _userInput = "";
    private List<ChatMessage> _messages = new();
    private ElementReference _messagesContainer;
    private string _currentPage = "";
    private DotNetObjectReference<AiAdvisorPanel>? _dotNetRef;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        _currentPage = GetPageName(Navigation.Uri);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Register for AI help icon clicks
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerAiAdvisorCallback", _dotNetRef);
        }
    }

    /// <summary>
    /// Called from JavaScript when an AI help icon is clicked
    /// </summary>
    [JSInvokable]
    public async Task ReceiveContextFromHelpIcon(string context)
    {
        if (string.IsNullOrWhiteSpace(context)) return;

        // Expand the panel
        _isExpanded = true;

        // Add a user message with the context
        _messages.Add(new ChatMessage
        {
            IsUser = true,
            Text = $"Help me understand this:\n{context}",
            Timestamp = DateTime.Now
        });

        StateHasChanged();
        await ScrollToBottom();

        // Get AI response
        _isAnalyzing = true;
        StateHasChanged();

        try
        {
            var response = await AiAdvisor.GetAdviceAsync($"Explain this to me as a trading advisor. Be concise and helpful:\n\n{context}", _currentPage);

            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = response,
                Timestamp = DateTime.Now
            });
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"❌ Error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var newPage = GetPageName(e.Location);
        if (newPage != _currentPage)
        {
            _currentPage = newPage;
            // Auto-analyze on page change if expanded
            if (_isExpanded && !_isAnalyzing)
            {
                _ = AutoAnalyzePageChange();
            }
        }
    }
    
    private async Task AutoAnalyzePageChange()
    {
        await Task.Delay(500); // Wait for page to render
        await InvokeAsync(StateHasChanged);
    }
    
    private string GetPageName(string uri)
    {
        var path = new Uri(uri).AbsolutePath.TrimStart('/');
        return string.IsNullOrEmpty(path) ? "Dashboard" : path.Split('/')[0];
    }
    
    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }
    
    private async Task CaptureAndAnalyze()
    {
        if (_isAnalyzing) return;

        _isAnalyzing = true;
        StateHasChanged();

        try
        {
            // Capture screenshot using JavaScript
            var screenshotData = await JS.InvokeAsync<string>("captureScreenshot");

            // Also extract the page context from data-analysis/data-meta attributes
            var pageContext = await JS.InvokeAsync<string>("getPageSummary");

            if (!string.IsNullOrEmpty(screenshotData))
            {
                // Add user message with screenshot
                _messages.Add(new ChatMessage
                {
                    IsUser = true,
                    Text = $"Analyzing the {_currentPage} page...",
                    Timestamp = DateTime.Now,
                    HasImage = true,
                    ImageData = screenshotData
                });

                await ScrollToBottom();
                StateHasChanged();

                // Send to AI for analysis with context
                var analysis = await AiAdvisor.AnalyzeScreenshotAsync(screenshotData, _currentPage, pageContext);

                _messages.Add(new ChatMessage
                {
                    IsUser = false,
                    Text = analysis,
                    Timestamp = DateTime.Now
                });

                await ScrollToBottom();
            }
            else
            {
                _messages.Add(new ChatMessage
                {
                    IsUser = false,
                    Text = "⚠️ Couldn't capture the screen. Make sure the page is fully loaded.",
                    Timestamp = DateTime.Now
                });
            }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"❌ Error analyzing screen: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }
    
    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_userInput) || _isAnalyzing) return;
        
        var userMessage = _userInput.Trim();
        _userInput = "";
        _isAnalyzing = true;
        
        _messages.Add(new ChatMessage
        {
            IsUser = true,
            Text = userMessage,
            Timestamp = DateTime.Now
        });
        
        await ScrollToBottom();
        StateHasChanged();
        
        try
        {
            var response = await AiAdvisor.GetAdviceAsync(userMessage, _currentPage);
            
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = response,
                Timestamp = DateTime.Now
            });
            
            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"❌ Error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }
    
    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_userInput))
        {
            await SendMessage();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(50);
        await JS.InvokeVoidAsync("scrollToBottom", _messagesContainer);
    }

    private async Task AskQuickQuestion(string question)
    {
        if (_isAnalyzing) return;

        // Expand panel if collapsed
        _isExpanded = true;

        _isAnalyzing = true;
        StateHasChanged();

        _messages.Add(new ChatMessage
        {
            IsUser = true,
            Text = question,
            Timestamp = DateTime.Now
        });

        await ScrollToBottom();

        try
        {
            // Get page context for better answers
            var pageContext = await JS.InvokeAsync<string>("getPageSummary");
            var contextEnhancedQuestion = $"{question}\n\nCurrent page context:\n{pageContext}";

            var response = await AiAdvisor.GetAdviceAsync(contextEnhancedQuestion, _currentPage);

            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = response,
                Timestamp = DateTime.Now
            });

            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"❌ Error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }

    private async Task ExtractAndShowContext()
    {
        if (_isAnalyzing) return;

        _isExpanded = true;

        try
        {
            var context = await JS.InvokeAsync<object>("extractAnalysisContext");
            var contextJson = JsonSerializer.Serialize(context, new JsonSerializerOptions { WriteIndented = true });

            _messages.Add(new ChatMessage
            {
                IsUser = true,
                Text = "📋 Extracted page context",
                Timestamp = DateTime.Now
            });

            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"**Page Data Extracted:**\n\n```json\n{contextJson}\n```\n\nThis data is used to provide you with contextual analysis. All elements with `data-analysis` and `data-meta` attributes are captured and sent to the AI for accurate insights.",
                Timestamp = DateTime.Now
            });

            await ScrollToBottom();
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = $"❌ Error extracting context: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }

        StateHasChanged();
    }

    private string FormatMessage(string text)
    {
        // Convert markdown-style formatting to HTML
        return text
            .Replace("```json", "<pre><code class='json'>")
            .Replace("```", "</code></pre>")
            .Replace("\n", "<br/>")
            .Replace("**", "<strong>")
            .Replace("*", "<em>");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        _dotNetRef?.Dispose();
    }

    private class ChatMessage
    {
        public bool IsUser { get; set; }
        public string Text { get; set; } = "";
        public DateTime Timestamp { get; set; }
        public bool HasImage { get; set; }
        public string? ImageData { get; set; }
    }
}
