    // Settings methods
    private async Task InitializeSettings()
    {
        // Try to load from local storage first
        if (_isJsReady)
        {
            await LoadFromLocalStorage();
        }
        else
        {
            _backtestSettings = new BacktestSettings();
        }
        UpdateSettingsJson();
    }

    private void SyncSettingsToJson()
    {
        UpdateSettingsJson();
        _settingsSaved = false;
    }

    private void UpdateSettingsJson()
    {
        var options = new JsonSerializerOptions { WriteIndented = true };
        _settingsJson = JsonSerializer.Serialize(_backtestSettings, options);
        _settingsJsonDirty = false;
        _settingsJsonError = null;
    }

    private void OnSettingsJsonChanged()
    {
        _settingsJsonDirty = true;
        _settingsSaved = false;
        try
        {
            var parsed = JsonSerializer.Deserialize<BacktestSettings>(_settingsJson);
            if (parsed != null)
            {
                _settingsJsonError = null;
            }
        }
        catch (JsonException ex)
        {
            _settingsJsonError = $"Invalid JSON: {ex.Message}";
        }
    }

    private void FormatJson()
    {
        try
        {
            var parsed = JsonSerializer.Deserialize<BacktestSettings>(_settingsJson);
            if (parsed != null)
            {
                var options = new JsonSerializerOptions { WriteIndented = true };
                _settingsJson = JsonSerializer.Serialize(parsed, options);
                _settingsJsonError = null;
            }
        }
        catch (JsonException ex)
        {
            _settingsJsonError = $"Cannot format: {ex.Message}";
        }
    }

    private void ResetSettings()
    {
        _backtestSettings = new BacktestSettings();
        UpdateSettingsJson();
        _settingsSaved = false;
    }

    private void ApplySettings()
    {
        try
        {
            var parsed = JsonSerializer.Deserialize<BacktestSettings>(_settingsJson);
            if (parsed != null)
            {
                _backtestSettings = parsed;
                _settingsJsonDirty = false;
                _settingsJsonError = null;
                _settingsSaved = true;
            }
        }
        catch (JsonException ex)
        {
            _settingsJsonError = $"Cannot apply: {ex.Message}";
        }
    }

    private async Task SaveToLocalStorage()
    {
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, _settingsJson);
            _settingsSaved = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to save settings: {ex.Message}");
        }
    }

    private async Task LoadFromLocalStorage()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageKey);
            if (!string.IsNullOrEmpty(json))
            {
                var parsed = JsonSerializer.Deserialize<BacktestSettings>(json);
                if (parsed != null)
                {
                    _backtestSettings = parsed;
                    _settingsSaved = true;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load settings: {ex.Message}");
            _backtestSettings = new BacktestSettings();
        }
    }

    private async Task ExportSettings()
    {
        try
        {
            var json = JsonSerializer.Serialize(_backtestSettings, new JsonSerializerOptions { WriteIndented = true });
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);

            await JS.InvokeVoidAsync("eval", $@"
                const link = document.createElement('a');
                link.href = 'data:application/json;base64,{base64}';
                link.download = 'backtest-settings.json';
                link.click();
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Export failed: {ex.Message}");
        }
    }

    private async Task ImportSettings(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file.Size > 1024 * 100) // 100KB limit
            {
                _settingsJsonError = "File too large (max 100KB)";
                return;
            }

            using var stream = file.OpenReadStream();
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var parsed = JsonSerializer.Deserialize<BacktestSettings>(json);
            if (parsed != null)
            {
                _backtestSettings = parsed;
                UpdateSettingsJson();
                _settingsSaved = false;
                _settingsJsonError = null;
            }
        }
        catch (JsonException ex)
        {
            _settingsJsonError = $"Invalid JSON file: {ex.Message}";
        }
        catch (Exception ex)
        {
            _settingsJsonError = $"Import failed: {ex.Message}";
        }

        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _playbackTimer?.Dispose();

        if (_isJsReady)
        {
            try
            {
                await JS.InvokeVoidAsync("destroyChart");
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected, ignore
            }
        }
    }
    
    // Models
    private sealed class SessionStats
    {
        public double Open { get; set; }
        public double High { get; set; }
        public double Low { get; set; }
        public double Close { get; set; }
        public double Range { get; set; }
        public double RangePercent { get; set; }
        public double TotalVolume { get; set; }
        public double AverageVolume { get; set; }
        public int CandleCount { get; set; }
    }
    
    private sealed class SimulatedTrade
    {
        public bool IsLong { get; set; }
        public double EntryPrice { get; set; }
        public DateTime EntryTime { get; set; }
        public double ExitPrice { get; set; }
        public DateTime ExitTime { get; set; }
        public double PnL { get; set; }
    }

    private sealed class BacktestSettings
    {
        public bool ShowDailyDetails { get; set; } = false;
        public bool UseStopLoss { get; set; } = true;
        public bool UseTrailingStopLoss { get; set; } = false;
        public int PositionSize { get; set; } = 10;
        public double StopLossPercent { get; set; } = 2.0;
