@page "/backtest"
@page "/backtest/{Symbol}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using IdiotProof.Web.Services.TradingView
@using IdiotProof.Web.Components.Shared
@using IdiotProof.Shared
@using Microsoft.JSInterop
@using System.Text.Json
@using System.IO
@using Microsoft.AspNetCore.Components.Forms
@inject HistoricalDataProvider HistoricalData
@inject ChartDataService ChartService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Backtest - @(Symbol ?? "Select Symbol")</PageTitle>

<div class="backtest-page" data-meta="Backtest visualization page for replaying historical trades with technical indicators">
    <header class="backtest-header" data-meta="Controls for selecting symbol, date, and timeframe">
        <div class="header-left">
            <h1>📊 Backtest Visualization <AiHelpIcon Context="What is backtesting? Explain how to use this visualization page to analyze historical trades and improve my trading strategy." /></h1>
            <span class="subtitle">Replay historical trades with your indicators</span>
        </div>

        <div class="controls" data-analysis="Symbol and date selection determines which historical data to load for backtesting">
            <select @bind="_selectedSymbol" @bind:after="OnSymbolChanged" class="symbol-select"
                    data-meta="Stock symbol selector - available symbols come from collected historical data">
                <option value="">-- Select Symbol --</option>
                @foreach (var symbol in _availableSymbols)
                {
                    <option value="@symbol">@symbol</option>
                }
            </select>

            <select @bind="_selectedDate" @bind:after="OnDateChanged" class="date-select" disabled="@string.IsNullOrEmpty(_selectedSymbol)"
                    data-meta="Trading date selector - shows dates where candle data was collected">
                <option value="">-- Select Date --</option>
                @foreach (var date in _availableDates)
                {
                    <option value="@date.ToString("yyyy-MM-dd")">@date.ToString("ddd MMM dd, yyyy")</option>
                }
            </select>

            <select @bind="_intervalMinutes" @bind:after="OnIntervalChanged" class="interval-select"
                    data-meta="Candle interval - aggregates 1-min data into larger timeframes. Larger intervals smooth noise but lose granularity.">
                <option value="1">1 min</option>
                <option value="5">5 min</option>
                <option value="15">15 min</option>
                <option value="30">30 min</option>
                <option value="60">1 hour</option>
            </select>
        </div>
    </header>

    <div class="chart-toolbar" data-meta="Chart controls for indicators, playback, and view manipulation">
        <div class="indicator-toggles" data-analysis="Technical indicators overlay on price chart. VWAP=Volume Weighted Avg Price (institutional levels). EMAs=Exponential Moving Averages (trend direction).">
            <label data-meta="VWAP: Key institutional level. Price above=bullish, below=bearish."><input type="checkbox" @bind="_showVwap" @bind:after="UpdateOverlays" /> VWAP</label>
            <label data-meta="EMA 9: Fast moving average. Reacts quickly to price changes."><input type="checkbox" @bind="_showEma9" @bind:after="UpdateOverlays" /> EMA 9</label>
            <label data-meta="EMA 21: Medium moving average. EMA9 crossing EMA21 = trend signal."><input type="checkbox" @bind="_showEma21" @bind:after="UpdateOverlays" /> EMA 21</label>
            <label data-meta="EMA 50: Slow moving average. Major trend direction indicator."><input type="checkbox" @bind="_showEma50" @bind:after="UpdateOverlays" /> EMA 50</label>
        </div>

        <div class="playback-controls" data-analysis="Replay historical price action candle-by-candle to study how trades would have developed">
            <button class="btn-icon" @onclick="() => StepBackward()" disabled="@(!_canPlayback)" title="Step Back">⏮️</button>
            <button class="btn-icon" @onclick="() => TogglePlayback()" disabled="@(!_canPlayback)" title="@(_isPlaying ? "Pause" : "Play")">
                @(_isPlaying ? "⏸️" : "▶️")
            </button>
            <button class="btn-icon" @onclick="() => StepForward()" disabled="@(!_canPlayback)" title="Step Forward">⏭️</button>
            <input type="range" min="1" max="100" @bind="_playbackSpeed" class="speed-slider" title="Playback Speed" 
                   data-meta="Playback speed: Higher=faster replay. Use slower speeds to study price action." />
            <span class="speed-label">@(_playbackSpeed)x</span>
        </div>

        <div class="view-controls">
            <button class="btn-small" @onclick="FitContent">Fit All</button>
            <button class="btn-small" @onclick="ScrollToStart">To Start</button>
            <button class="btn-small" @onclick="ScrollToEnd">To End</button>
        </div>
    </div>

    <div class="main-content">
        <div class="chart-container" id="backtest-chart">
            @if (_isLoading)
            {
                <div class="loading-overlay">
                    <div class="spinner"></div>
                    <span>Loading historical data...</span>
                </div>
            }
            else if (!_hasData)
            {
                <div class="empty-state">
                    <span class="empty-icon">📈</span>
                    <p>Select a symbol and date to load historical data</p>
                    <p class="hint">Your collected candle data will be visualized here</p>
                </div>
            }
        </div>

        <div class="stats-panel">
            <div class="panel-tabs">
                <button class="tab-btn @(_activeTab == "stats" ? "active" : "")" @onclick="@(() => _activeTab = "stats")">📊 Statistics</button>
                <button class="tab-btn @(_activeTab == "trades" ? "active" : "")" @onclick="@(() => _activeTab = "trades")">🎯 Trades</button>
                <button class="tab-btn @(_activeTab == "settings" ? "active" : "")" @onclick="@(() => _activeTab = "settings")">⚙️ Settings</button>
            </div>

            @if (_activeTab == "stats")
            {
                <h3>📊 Session Statistics <AiHelpIcon Context="Explain these session statistics. What do Open, High, Low, Close (OHLC) tell me? How should I interpret the Range% and Volume data for trading decisions?" /></h3>

                @if (_sessionStats != null)
                {
                    <div class="stat-grid" data-analysis="Session OHLC data for @_selectedSymbol on @_selectedDate. Range% indicates volatility. Volume confirms price moves.">
                        <div class="stat-item" data-meta="Opening price: First trade of the session. Compare to Close for daily direction.">
                            <span class="stat-label">Open</span>
                            <span class="stat-value">$@_sessionStats.Open.ToString("F2")</span>
                        </div>
                        <div class="stat-item" data-meta="Session high: Resistance level. Failed breakouts above are bearish.">
                            <span class="stat-label">High</span>
                            <span class="stat-value high">$@_sessionStats.High.ToString("F2")</span>
                        </div>
                        <div class="stat-item" data-meta="Session low: Support level. Failed breakdowns below are bullish.">
                            <span class="stat-label">Low</span>
                            <span class="stat-value low">$@_sessionStats.Low.ToString("F2")</span>
                        </div>
                        <div class="stat-item" data-meta="Closing price: Last trade. Close>Open=bullish day, Close<Open=bearish day.">
                            <span class="stat-label">Close</span>
                            <span class="stat-value">$@_sessionStats.Close.ToString("F2")</span>
                        </div>
                        <div class="stat-item" data-meta="Price range: High-Low. Higher range=more volatility=more opportunity but more risk.">
                            <span class="stat-label">Range</span>
                            <span class="stat-value">$@_sessionStats.Range.ToString("F2") (@_sessionStats.RangePercent.ToString("F1")%)</span>
                        </div>
                        <div class="stat-item" data-meta="Total volume: All shares traded. Higher volume validates price moves.">
                            <span class="stat-label">Volume</span>
                            <span class="stat-value">@FormatVolume(_sessionStats.TotalVolume)</span>
                        </div>
                        <div class="stat-item" data-meta="Candle count: Number of price bars. More candles=more data points for analysis.">
                            <span class="stat-label">Candles</span>
                            <span class="stat-value">@_sessionStats.CandleCount</span>
                        </div>
                        <div class="stat-item" data-meta="Average volume per candle: Baseline for volume analysis. Spikes above are significant.">
                            <span class="stat-label">Avg Volume</span>
                            <span class="stat-value">@FormatVolume(_sessionStats.AverageVolume)</span>
                        </div>
                    </div>
                }
            }

            @if (_activeTab == "trades")
            {
                <h3>🎯 Simulated Trades <AiHelpIcon Context="Explain what these simulated trades show. How do I interpret Total P&L, Win Rate, and Profit Factor? What makes a good backtest result?" /></h3>

                <div class="strategy-selector">
                    <label>Strategy:</label>
                    <select @bind="_selectedStrategy" class="strategy-select">
                        <option value="ema-crossover">EMA Crossover</option>
                        <option value="vwap-bounce">VWAP Bounce</option>
                        <option value="momentum">Momentum</option>
                    </select>
                </div>

                <div class="strategy-description">
                    @switch (_selectedStrategy)
                    {
                        case "ema-crossover":
                            <p>📈 <strong>EMA Crossover:</strong> Enters LONG when EMA @(_backtestSettings.EmaCrossoverShort) crosses above EMA @(_backtestSettings.EmaCrossoverLong), SHORT when it crosses below. Classic trend-following strategy. <AiHelpIcon Context="Explain the EMA Crossover strategy in detail. How does it work? What are its strengths and weaknesses? When does it perform best?" /></p>
                            break;
                        case "vwap-bounce":
                            <p>📊 <strong>VWAP Bounce:</strong> Enters when price bounces off VWAP (support/resistance). LONG on bounce up from VWAP, SHORT on rejection down from VWAP. <AiHelpIcon Context="Explain the VWAP Bounce strategy. What is VWAP and why do prices bounce off it? When should I use this strategy?" /></p>
                            break;
                        case "momentum":
                            <p>🚀 <strong>Momentum:</strong> Enters on strong price momentum (ROC over 1.5%) with EMA alignment and consecutive candle confirmation. Catches explosive moves. <AiHelpIcon Context="Explain the Momentum strategy. What is Rate of Change (ROC)? How does this strategy catch explosive moves?" /></p>
                            break;
                    }
                </div>

                @if (_simulatedTrades.Count > 0)
                {
                    <div class="performance-summary" data-analysis="Key performance metrics: PnL=profit/loss, WinRate=% profitable trades, ProfitFactor=gross profit/gross loss (>1 is profitable)">
                        <div class="perf-card @(_totalPnL >= 0 ? "profit" : "loss")" 
                             data-meta="Total P&L: Net profit/loss. @(_totalPnL >= 0 ? "Positive=strategy is profitable" : "Negative=strategy needs adjustment")">
                            <span class="perf-label">Total P&amp;L <AiHelpIcon Context="@($"My backtest shows Total P&L of ${_totalPnL:F2}. Is this good? How should I interpret this result? What factors affect P&L?")" /></span>
                            <span class="perf-value">@(_totalPnL >= 0 ? "+" : "")$@_totalPnL.ToString("F2")</span>
                        </div>
                        <div class="perf-card" data-meta="Win Rate: @_winRate.ToString("F1")%. Target >50%. Below 40% requires high R:R to be profitable.">
                            <span class="perf-label">Win Rate <AiHelpIcon Context="@($"My backtest shows Win Rate of {_winRate:F1}%. Is this good? What win rate do professional traders aim for?")" /></span>
                            <span class="perf-value">@_winRate.ToString("F1")%</span>
                        </div>
                        <div class="perf-card" data-meta="Trade count: @_simulatedTrades.Count trades. More trades=more statistical significance.">
                            <span class="perf-label">Trades</span>
                            <span class="perf-value">@_simulatedTrades.Count</span>
                        </div>
                        <div class="perf-card @(_profitFactor >= 1 ? "profit" : "loss")" 
                             data-meta="Profit Factor: @_profitFactor.ToString("F2"). >1.5=good, >2.0=excellent. <1=losing strategy.">
                            <span class="perf-label">Profit Factor <AiHelpIcon Context="@($"My Profit Factor is {_profitFactor:F2}. Explain what Profit Factor means and whether this is a good number.")" /></span>
                            <span class="perf-value">@_profitFactor.ToString("F2")</span>
                        </div>
                    </div>

                    <div class="advanced-stats" data-analysis="Risk metrics: Expectancy=avg profit per trade. MaxDD=worst peak-to-trough decline. AvgWin/Loss ratio determines required win rate.">
                        <div class="stat-row" data-meta="Average winning trade. Higher avg win allows lower win rate.">
                            <span>Avg Win:</span>
                            <span class="profit">+$@_avgWin.ToString("F2")</span>
                        </div>
                        <div class="stat-row" data-meta="Average losing trade. Smaller losses = better risk management.">
                            <span>Avg Loss:</span>
                            <span class="loss">-$@Math.Abs(_avgLoss).ToString("F2")</span>
                        </div>
                        <div class="stat-row" data-meta="Max Drawdown: Largest equity decline. Risk of ruin indicator. Should be <20% of capital.">
                            <span>Max Drawdown: <AiHelpIcon Context="@($"My Max Drawdown is ${_maxDrawdown:F2}. Explain what drawdown means and how to reduce it.")" /></span>
                            <span class="loss">$@_maxDrawdown.ToString("F2")</span>
                        </div>
                        <div class="stat-row" data-meta="Expectancy: Average profit per trade. Must be positive for long-term profitability.">
                            <span>Expectancy: <AiHelpIcon Context="@($"My Expectancy is ${_expectancy:F2}. What does expectancy mean and is this a good number?")" /></span>
                            <span class="@(_expectancy >= 0 ? "profit" : "loss")">$@_expectancy.ToString("F2")</span>
                        </div>
                        <div class="stat-row" data-meta="Best trade: Shows upside potential of the strategy.">
                            <span>Largest Win:</span>
                            <span class="profit">+$@_largestWin.ToString("F2")</span>
                        </div>
                        <div class="stat-row" data-meta="Worst trade: Shows maximum single-trade risk. Should be limited by stop-loss.">
                            <span>Largest Loss:</span>
                            <span class="loss">-$@Math.Abs(_largestLoss).ToString("F2")</span>
                        </div>
                    </div>

                    <div class="equity-curve-section">
                        <h4>📈 Equity Curve <AiHelpIcon Context="Explain what the equity curve shows. What patterns should I look for? What does a healthy equity curve look like?" /></h4>
                        <div class="equity-curve">
                            @{
                                var equityPoints = GetEquityCurvePoints();
                                var maxEquity = equityPoints.Max();
                                var minEquity = equityPoints.Min();
                                var range = maxEquity - minEquity;
                                if (range == 0) range = 1;
                            }
                            <svg viewBox="0 0 300 80" class="equity-svg">
                                <defs>
                                    <linearGradient id="equityGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                                        <stop offset="0%" style="stop-color:@(_totalPnL >= 0 ? "#238636" : "#f85149");stop-opacity:0.3" />
                                        <stop offset="100%" style="stop-color:@(_totalPnL >= 0 ? "#238636" : "#f85149");stop-opacity:0" />
                                    </linearGradient>
                                </defs>
                                @if (equityPoints.Count > 1)
                                {
                                    var points = string.Join(" ", equityPoints.Select((v, i) => 
                                        $"{i * 300.0 / (equityPoints.Count - 1)},{80 - ((v - minEquity) / range * 70 + 5)}"));
                                    var areaPoints = $"0,80 {points} 300,80";
                                    <polygon points="@areaPoints" fill="url(#equityGrad)" />
                                    <polyline points="@points" fill="none" stroke="@(_totalPnL >= 0 ? "#238636" : "#f85149")" stroke-width="2" />
                                }
                            </svg>
                            <div class="equity-labels">
                                <span>Start: $0</span>
                                <span>End: @(_totalPnL >= 0 ? "+" : "")$@_totalPnL.ToString("F2")</span>
                            </div>
                        </div>
                    </div>

                    <div class="trades-list" data-analysis="Individual trade log showing entry/exit points and P&L for each position">
                        @foreach (var trade in _simulatedTrades)
                        {
                            var holdTime = (trade.ExitTime - trade.EntryTime).TotalMinutes;
                            var pnlPercent = trade.IsLong 
                                ? ((trade.ExitPrice - trade.EntryPrice) / trade.EntryPrice) * 100
                                : ((trade.EntryPrice - trade.ExitPrice) / trade.EntryPrice) * 100;
                            <div class="trade-item @(trade.PnL >= 0 ? "profit" : "loss")"
                                 data-analysis="@(trade.IsLong ? "LONG" : "SHORT") trade: Entry $@trade.EntryPrice.ToString("F2") → Exit $@trade.ExitPrice.ToString("F2"). Held @holdTime.ToString("F0") min. @(pnlPercent >= 0 ? "Profit" : "Loss") @Math.Abs(pnlPercent).ToString("F2")%">
                                <div class="trade-header">
                                    <span class="trade-direction @(trade.IsLong ? "long" : "short")"
                                          data-meta="@(trade.IsLong ? "LONG: Bought expecting price to rise" : "SHORT: Sold expecting price to fall")">
                                        @(trade.IsLong ? "LONG" : "SHORT")
                                    </span>
                                    <span class="trade-pnl @(trade.PnL >= 0 ? "profit" : "loss")">
                                        @(trade.PnL >= 0 ? "+" : "")$@trade.PnL.ToString("F2")
                                    </span>
                                </div>
                                <div class="trade-details">
                                    <span>Entry: $@trade.EntryPrice.ToString("F2") @@ @trade.EntryTime.ToString("HH:mm")</span>
                                    <span>Exit: $@trade.ExitPrice.ToString("F2") @@ @trade.ExitTime.ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="no-trades">No trades simulated yet. Select a strategy and run the simulation.</p>
                }

                <button class="btn-run-backtest" @onclick="RunSimulation" disabled="@(!_hasData)">
                    🚀 Run Strategy Simulation
                </button>
            }

            @if (_activeTab == "settings")
            {
                <h3>⚙️ Backtest Settings <AiHelpIcon Context="Explain these backtest settings. What Position Size should I use? How do I choose Stop Loss and Take Profit percentages? What are good values for EMA periods?" /></h3>

                <div class="settings-section">
                    <div class="setting-group">
                        <label class="setting-label">
                            <input type="checkbox" @bind="_backtestSettings.ShowDailyDetails" @bind:after="SyncSettingsToJson" />
                            Show Daily Details
                        </label>
                        <span class="setting-hint">Display individual trade details per day</span>
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">
                            <input type="checkbox" @bind="_backtestSettings.UseStopLoss" @bind:after="SyncSettingsToJson" />
                            Use Stop Loss
                        </label>
                        <span class="setting-hint">Enable stop loss orders in simulation</span>
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">
                            <input type="checkbox" @bind="_backtestSettings.UseTrailingStopLoss" @bind:after="SyncSettingsToJson" />
                            Use Trailing Stop Loss
                        </label>
                        <span class="setting-hint">Enable trailing stop for protecting gains</span>
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">Position Size (shares)</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.PositionSize" @bind:after="SyncSettingsToJson" min="1" max="1000" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">Stop Loss %</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.StopLossPercent" @bind:after="SyncSettingsToJson" min="0.1" max="10" step="0.1" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">Take Profit %</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.TakeProfitPercent" @bind:after="SyncSettingsToJson" min="0.1" max="20" step="0.1" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">Trailing Stop %</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.TrailingStopPercent" @bind:after="SyncSettingsToJson" min="0.1" max="10" step="0.1" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">EMA Short Period</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.EmaCrossoverShort" @bind:after="SyncSettingsToJson" min="3" max="50" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">EMA Long Period</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.EmaCrossoverLong" @bind:after="SyncSettingsToJson" min="10" max="200" />
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">
                            <input type="checkbox" @bind="_backtestSettings.RequireVwapConfirmation" @bind:after="SyncSettingsToJson" />
                            Require VWAP Confirmation
                        </label>
                        <span class="setting-hint">Only enter long above VWAP, short below</span>
                    </div>

                    <div class="setting-group">
                        <label class="setting-label">Min Volume Ratio</label>
                        <input type="number" class="setting-input" @bind="_backtestSettings.MinVolumeRatio" @bind:after="SyncSettingsToJson" min="0.5" max="5" step="0.1" />
                        <span class="setting-hint">Volume must be X times average to enter</span>
                    </div>
                </div>

                <div class="settings-json-section">
                    <div class="json-header">
                        <span>📝 JSON Editor</span>
                        <div class="json-actions">
                            <button class="btn-small" @onclick="FormatJson" title="Format JSON">Format</button>
                            <button class="btn-small" @onclick="ResetSettings" title="Reset to defaults">Reset</button>
                            <button class="btn-small" @onclick="ExportSettings" title="Download settings">Export</button>
                            <label class="btn-small import-btn">
                                Import
                                <InputFile OnChange="ImportSettings" accept=".json" style="display:none" />
                            </label>
                        </div>
                    </div>
                    <textarea class="settings-json-editor @(_settingsJsonError != null ? "error" : "")" 
                              @bind="_settingsJson" 
                              @bind:after="OnSettingsJsonChanged"
                              rows="14"
                              spellcheck="false"></textarea>
                    @if (_settingsJsonError != null)
                    {
                        <div class="json-error">⚠️ @_settingsJsonError</div>
                    }
                    else if (_settingsJsonDirty)
                    {
                        <div class="json-dirty">✏️ Unsaved changes - click Apply to use</div>
                    }
                    else if (_settingsSaved)
                    {
                        <div class="json-saved">✅ Settings applied</div>
                    }
                </div>

                <div class="settings-actions">
                    <button class="btn-apply" @onclick="ApplySettings" disabled="@(_settingsJsonError != null || !_settingsJsonDirty)">
                        ✅ Apply Settings
                    </button>
                    <button class="btn-save" @onclick="SaveToLocalStorage" title="Save to browser storage">
                        💾 Save
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Symbol { get; set; }
    
    // Data
    private List<string> _availableSymbols = [];
    private List<DateTime> _availableDates = [];
    private List<ChartDataPoint> _candles = [];
    private ChartBundle? _chartBundle;
    
    // UI State
    private string _selectedSymbol = "";
    private string _selectedDate = "";
    private int _intervalMinutes = 1;
    private bool _isLoading;
    private bool _hasData;
    
    // Indicators
    private bool _showVwap = true;
    private bool _showEma9 = true;
    private bool _showEma21 = true;
    private bool _showEma50 = false;
    
    // Playback
    private bool _isPlaying;
    private bool _canPlayback;
    private int _playbackSpeed = 10;
    private int _currentCandleIndex;
    private Timer? _playbackTimer;

    // JS interop readiness
    private bool _isJsReady;
    private bool _pendingRender;
    
    // Statistics
    private SessionStats? _sessionStats;
    private List<SimulatedTrade> _simulatedTrades = [];
    private double _totalPnL;
    private double _winRate;
    private double _profitFactor;
    private double _avgWin;
    private double _avgLoss;
    private double _maxDrawdown;
    private double _expectancy;
    private double _largestWin;
    private double _largestLoss;

    // Strategy
    private string _selectedStrategy = "ema-crossover";

    // Tabs
    private string _activeTab = "stats";

    // Settings
    private BacktestSettings _backtestSettings = new();
    private string _settingsJson = "";
    private string? _settingsJsonError;
    private bool _settingsJsonDirty;
    private bool _settingsSaved;
    private const string LocalStorageKey = "idiotproof_backtest_settings";

    protected override async Task OnInitializedAsync()
    {
        _availableSymbols = HistoricalData.GetAvailableSymbols();
        await InitializeSettings();

        if (!string.IsNullOrEmpty(Symbol) && _availableSymbols.Contains(Symbol.ToUpperInvariant()))
        {
            _selectedSymbol = Symbol.ToUpperInvariant();
            // Load data but don't render chart yet (JS not ready during prerender)
            await LoadDataForSymbol();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initializeChart", "backtest-chart", new { height = 500 });
            _isJsReady = true;

            // Load settings from local storage now that JS is ready
            await LoadFromLocalStorage();
            UpdateSettingsJson();

            // Render any pending chart data
            if (_pendingRender && _hasData)
            {
                await RenderChart();
                _pendingRender = false;
            }

            StateHasChanged();
        }
    }

    private async Task LoadDataForSymbol()
    {
        if (string.IsNullOrEmpty(_selectedSymbol))
        {
            _availableDates = [];
            return;
        }

        _isLoading = true;

        try
        {
            _availableDates = await HistoricalData.GetTradingDaysAsync(_selectedSymbol);

            if (_availableDates.Count > 0)
            {
                _selectedDate = _availableDates.Last().ToString("yyyy-MM-dd");
                await LoadDataForDate();
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDataForDate()
    {
        if (string.IsNullOrEmpty(_selectedSymbol) || string.IsNullOrEmpty(_selectedDate))
            return;

        if (!DateTime.TryParse(_selectedDate, out var date))
            return;

        _candles = await HistoricalData.GetDayDataAsync(_selectedSymbol, date, _intervalMinutes);
        _hasData = _candles.Count > 0;
        _canPlayback = _hasData;
        _currentCandleIndex = _candles.Count;

        if (_hasData)
        {
            var config = new ChartConfig
            {
                Symbol = _selectedSymbol,
                ShowVwap = _showVwap,
                ShowEma9 = _showEma9,
                ShowEma21 = _showEma21,
                ShowEma50 = _showEma50
            };
            _chartBundle = ChartService.PrepareChartData(_candles, config);
            CalculateSessionStats();
            _pendingRender = true;
        }
    }
    
    private async Task OnSymbolChanged()
    {
        if (string.IsNullOrEmpty(_selectedSymbol))
        {
            _availableDates = [];
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            _availableDates = await HistoricalData.GetTradingDaysAsync(_selectedSymbol);

            if (_availableDates.Count > 0)
            {
                _selectedDate = _availableDates.Last().ToString("yyyy-MM-dd");
                await OnDateChanged();
            }
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
