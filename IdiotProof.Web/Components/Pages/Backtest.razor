    // Simulation
    private async Task RunSimulation()
    {
        _simulatedTrades.Clear();

        if (_chartBundle?.Overlays == null || _candles.Count < 2) return;

        // Run the selected strategy
        switch (_selectedStrategy)
        {
            case "ema-crossover":
                RunEmaCrossoverStrategy();
                break;
            case "vwap-bounce":
                RunVwapBounceStrategy();
                break;
            case "momentum":
                RunMomentumStrategy();
                break;
        }

        // Calculate totals and advanced statistics
        CalculateTradeStatistics();

        // Add markers to chart
        if (_isJsReady && _simulatedTrades.Count > 0)
        {
            var markers = _simulatedTrades.SelectMany(t => new object[]
            {
                new { time = new DateTimeOffset(t.EntryTime).ToUnixTimeSeconds(), isEntry = true, isLong = t.IsLong, isProfit = false, label = t.IsLong ? "BUY" : "SHORT" },
                new { time = new DateTimeOffset(t.ExitTime).ToUnixTimeSeconds(), isEntry = false, isLong = t.IsLong, isProfit = t.PnL > 0, label = t.PnL > 0 ? "WIN" : "LOSS" }
            }).ToArray();

            await JS.InvokeVoidAsync("addTradeMarkers", (object)markers);
        }

        StateHasChanged();
    }

    private void RunEmaCrossoverStrategy()
    {
        var ema9 = _chartBundle!.Overlays.FirstOrDefault(o => o.Name == $"EMA {_backtestSettings.EmaCrossoverShort}") 
                   ?? _chartBundle.Overlays.FirstOrDefault(o => o.Name == "EMA 9");
        var ema21 = _chartBundle.Overlays.FirstOrDefault(o => o.Name == $"EMA {_backtestSettings.EmaCrossoverLong}")
                    ?? _chartBundle.Overlays.FirstOrDefault(o => o.Name == "EMA 21");

        if (ema9 == null || ema21 == null) return;

        bool inPosition = false;
        bool isLong = false;
        double entryPrice = 0;
        long entryTime = 0;

        for (int i = 1; i < _candles.Count; i++)
        {
            var candle = _candles[i];
            var prevCandle = _candles[i - 1];

            var currEma9 = ema9.Points.FirstOrDefault(p => p.Time == candle.Time).Value;
            var currEma21 = ema21.Points.FirstOrDefault(p => p.Time == candle.Time).Value;
            var prevEma9 = ema9.Points.FirstOrDefault(p => p.Time == prevCandle.Time).Value;
            var prevEma21 = ema21.Points.FirstOrDefault(p => p.Time == prevCandle.Time).Value;

            if (currEma9 == 0 || currEma21 == 0) continue;

            // Check exit conditions if in position
            if (inPosition)
            {
                var pnlPercent = isLong 
                    ? ((candle.Close - entryPrice) / entryPrice) * 100
                    : ((entryPrice - candle.Close) / entryPrice) * 100;

                bool hitStopLoss = _backtestSettings.UseStopLoss && pnlPercent <= -_backtestSettings.StopLossPercent;
                bool hitTakeProfit = pnlPercent >= _backtestSettings.TakeProfitPercent;
                bool emaCrossExit = (isLong && currEma9 < currEma21) || (!isLong && currEma9 > currEma21);

                if (hitStopLoss || hitTakeProfit || emaCrossExit)
                {
                    RecordTrade(isLong, entryPrice, entryTime, candle.Close, candle.Time);
                    inPosition = false;
                }
            }

            // Entry signals
            if (!inPosition)
            {
                if (prevEma9 <= prevEma21 && currEma9 > currEma21)
                {
                    inPosition = true;
                    isLong = true;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                }
                else if (prevEma9 >= prevEma21 && currEma9 < currEma21)
                {
                    inPosition = true;
                    isLong = false;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                }
            }
        }
    }

    private void RunVwapBounceStrategy()
    {
        var vwap = _chartBundle!.Overlays.FirstOrDefault(o => o.Name == "VWAP");
        var ema9 = _chartBundle.Overlays.FirstOrDefault(o => o.Name == "EMA 9");

        if (vwap == null) return;

        bool inPosition = false;
        bool isLong = false;
        double entryPrice = 0;
        long entryTime = 0;
        int barsInPosition = 0;
        const int minHoldBars = 3;

        for (int i = 2; i < _candles.Count; i++)
        {
            var candle = _candles[i];
            var prevCandle = _candles[i - 1];
            var prevPrevCandle = _candles[i - 2];

            var currVwap = vwap.Points.FirstOrDefault(p => p.Time == candle.Time).Value;
            var prevVwap = vwap.Points.FirstOrDefault(p => p.Time == prevCandle.Time).Value;

            if (currVwap == 0) continue;

            // Check exit conditions
            if (inPosition)
            {
                barsInPosition++;
                var pnlPercent = isLong 
                    ? ((candle.Close - entryPrice) / entryPrice) * 100
                    : ((entryPrice - candle.Close) / entryPrice) * 100;

                bool hitStopLoss = _backtestSettings.UseStopLoss && pnlPercent <= -_backtestSettings.StopLossPercent;
                bool hitTakeProfit = pnlPercent >= _backtestSettings.TakeProfitPercent;

                // Exit if price crosses back through VWAP in wrong direction (after min hold)
                bool vwapCrossExit = barsInPosition >= minHoldBars && 
                    ((isLong && candle.Close < currVwap) || (!isLong && candle.Close > currVwap));

                if (hitStopLoss || hitTakeProfit || vwapCrossExit)
                {
                    RecordTrade(isLong, entryPrice, entryTime, candle.Close, candle.Time);
                    inPosition = false;
                    barsInPosition = 0;
                }
            }

            // Entry: VWAP bounce pattern
            if (!inPosition)
            {
                // Long: Price dips to VWAP from above and bounces (low touches VWAP, close above)
                bool vwapBounceUp = prevCandle.Low <= prevVwap * 1.002 && // Within 0.2% of VWAP
                                    prevCandle.Close > prevVwap &&
                                    candle.Close > prevCandle.Close &&
                                    candle.Close > currVwap;

                // Short: Price rises to VWAP from below and rejects
                bool vwapBounceDown = prevCandle.High >= prevVwap * 0.998 &&
                                      prevCandle.Close < prevVwap &&
                                      candle.Close < prevCandle.Close &&
                                      candle.Close < currVwap;

                if (vwapBounceUp)
                {
                    inPosition = true;
                    isLong = true;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                    barsInPosition = 0;
                }
                else if (vwapBounceDown)
                {
                    inPosition = true;
                    isLong = false;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                    barsInPosition = 0;
                }
            }
        }
    }

    private void RunMomentumStrategy()
    {
        var ema9 = _chartBundle!.Overlays.FirstOrDefault(o => o.Name == "EMA 9");
        var ema21 = _chartBundle.Overlays.FirstOrDefault(o => o.Name == "EMA 21");

        if (ema9 == null || ema21 == null) return;

        bool inPosition = false;
        bool isLong = false;
        double entryPrice = 0;
        long entryTime = 0;
        const int lookback = 5;

        for (int i = lookback; i < _candles.Count; i++)
        {
            var candle = _candles[i];

            var currEma9 = ema9.Points.FirstOrDefault(p => p.Time == candle.Time).Value;
            var currEma21 = ema21.Points.FirstOrDefault(p => p.Time == candle.Time).Value;

            if (currEma9 == 0 || currEma21 == 0) continue;

            // Calculate momentum (Rate of Change)
            var lookbackCandle = _candles[i - lookback];
            var roc = ((candle.Close - lookbackCandle.Close) / lookbackCandle.Close) * 100;

            // Calculate consecutive up/down candles
            int consecutiveUp = 0;
            int consecutiveDown = 0;
            for (int j = i - 1; j >= Math.Max(0, i - 3); j--)
            {
                if (_candles[j].Close > _candles[j].Open) consecutiveUp++;
                else consecutiveDown++;
            }

            // Check exit conditions
            if (inPosition)
            {
                var pnlPercent = isLong 
                    ? ((candle.Close - entryPrice) / entryPrice) * 100
                    : ((entryPrice - candle.Close) / entryPrice) * 100;

                bool hitStopLoss = _backtestSettings.UseStopLoss && pnlPercent <= -_backtestSettings.StopLossPercent;
                bool hitTakeProfit = pnlPercent >= _backtestSettings.TakeProfitPercent;

                // Exit on momentum reversal
                bool momentumReversal = (isLong && roc < -1.0) || (!isLong && roc > 1.0);

                if (hitStopLoss || hitTakeProfit || momentumReversal)
                {
                    RecordTrade(isLong, entryPrice, entryTime, candle.Close, candle.Time);
                    inPosition = false;
                }
            }

            // Entry: Strong momentum with trend confirmation
            if (!inPosition)
            {
                // Long: Strong positive ROC + price above EMAs + consecutive green candles
                bool strongBullishMomentum = roc > 1.5 &&
                                              candle.Close > currEma9 &&
                                              currEma9 > currEma21 &&
                                              consecutiveUp >= 2;

                // Short: Strong negative ROC + price below EMAs + consecutive red candles
                bool strongBearishMomentum = roc < -1.5 &&
                                              candle.Close < currEma9 &&
                                              currEma9 < currEma21 &&
                                              consecutiveDown >= 2;

                if (strongBullishMomentum)
                {
                    inPosition = true;
                    isLong = true;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                }
                else if (strongBearishMomentum)
                {
                    inPosition = true;
                    isLong = false;
                    entryPrice = candle.Close;
                    entryTime = candle.Time;
                }
            }
        }
    }

    private void RecordTrade(bool isLong, double entryPrice, long entryTime, double exitPrice, long exitTime)
    {
        var pnl = isLong 
            ? (exitPrice - entryPrice) * _backtestSettings.PositionSize
            : (entryPrice - exitPrice) * _backtestSettings.PositionSize;

        _simulatedTrades.Add(new SimulatedTrade
        {
            IsLong = isLong,
            EntryPrice = entryPrice,
            EntryTime = DateTimeOffset.FromUnixTimeSeconds(entryTime).DateTime,
            ExitPrice = exitPrice,
            ExitTime = DateTimeOffset.FromUnixTimeSeconds(exitTime).DateTime,
            PnL = Math.Round(pnl, 2)
        });
    }

    private void CalculateTradeStatistics()
    {
        if (_simulatedTrades.Count == 0)
        {
            _totalPnL = 0;
            _winRate = 0;
            _profitFactor = 0;
            _avgWin = 0;
            _avgLoss = 0;
            _maxDrawdown = 0;
            _expectancy = 0;
            _largestWin = 0;
            _largestLoss = 0;
            return;
        }

        _totalPnL = _simulatedTrades.Sum(t => t.PnL);

        var winners = _simulatedTrades.Where(t => t.PnL > 0).ToList();
        var losers = _simulatedTrades.Where(t => t.PnL <= 0).ToList();

        _winRate = _simulatedTrades.Count > 0 ? (winners.Count / (double)_simulatedTrades.Count) * 100 : 0;

        var totalWins = winners.Sum(t => t.PnL);
        var totalLosses = Math.Abs(losers.Sum(t => t.PnL));
        _profitFactor = totalLosses > 0 ? totalWins / totalLosses : totalWins > 0 ? 99.99 : 0;

        _avgWin = winners.Count > 0 ? winners.Average(t => t.PnL) : 0;
        _avgLoss = losers.Count > 0 ? losers.Average(t => t.PnL) : 0;

        _largestWin = winners.Count > 0 ? winners.Max(t => t.PnL) : 0;
        _largestLoss = losers.Count > 0 ? losers.Min(t => t.PnL) : 0;

        // Calculate max drawdown from equity curve
        double equity = 0;
        double peak = 0;
        _maxDrawdown = 0;

        foreach (var trade in _simulatedTrades)
        {
            equity += trade.PnL;
            if (equity > peak) peak = equity;
            var drawdown = peak - equity;
            if (drawdown > _maxDrawdown) _maxDrawdown = drawdown;
        }

        // Expectancy = (Win% × Avg Win) - (Loss% × Avg Loss)
        var winPct = winners.Count / (double)_simulatedTrades.Count;
        var lossPct = losers.Count / (double)_simulatedTrades.Count;
        _expectancy = (winPct * _avgWin) + (lossPct * _avgLoss); // avgLoss is already negative
    }

    private List<double> GetEquityCurvePoints()
    {
        var points = new List<double> { 0 };
        double equity = 0;

        foreach (var trade in _simulatedTrades)
        {
            equity += trade.PnL;
            points.Add(equity);
        }

        return points;
    }

