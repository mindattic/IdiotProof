@page "/analyze"
@page "/analyze/{Symbol}"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using IdiotProof.Web.Services.TradingView
@using IdiotProof.Web.Services.AI
@using IdiotProof.Web.Services.MarketScanner
@using IdiotProof.Shared
@using Microsoft.JSInterop
@inject ChartDataService ChartService
@inject HistoricalDataProvider HistoricalData
@inject AiAdvisorService AiAdvisor
@inject MarketScannerService Scanner
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@Symbol Analysis - IdiotProof</PageTitle>

<div class="command-center">
    @* Header with symbol selector and confidence *@
    <header class="center-header">
        <div class="symbol-selector">
            <input type="text" @bind="_symbolInput" @bind:event="oninput" 
                   @onkeydown="OnSymbolKeyDown"
                   placeholder="Enter symbol..." class="symbol-input" />
            <button class="btn-go" @onclick="LoadSymbolAsync" title="Analyze this symbol's technical indicators">Analyze</button>
        </div>
        
        @if (_indicators != null)
        {
            <div class="confidence-display @GetScoreClass(_indicators.CalculateMarketScore())">
                <span class="score-value">@_indicators.CalculateMarketScore()</span>
                <span class="score-label">Market Score</span>
            </div>
        }
        
        <div class="quick-actions">
            @foreach (var candidate in _topGappers.Take(5))
            {
                <button class="quick-symbol @(candidate.Symbol == Symbol ? "active" : "")"
                        @onclick="() => LoadSymbol(candidate.Symbol)">
                    <span class="qs-symbol">@candidate.Symbol</span>
                    <span class="qs-change @(candidate.IsGapUp ? "up" : "down")">
                        @candidate.GapPercent.ToString("+0.0;-0.0")%
                    </span>
                    <span class="qs-conf">@candidate.ConfidenceScore%</span>
                </button>
            }
        </div>
    </header>

    <div class="center-main">
        @* Chart Panel (Top Half) *@
        <div class="chart-panel">
            <div class="chart-toolbar">
                <div class="interval-selector">
                    @foreach (var interval in new[] { "1", "5", "15", "30", "60" })
                    {
                        <button class="@(_chartConfig.Interval == interval ? "active" : "")"
                                @onclick="() => SetInterval(interval)">@interval@(interval == "60" ? "H" : "m")</button>
                    }
                </div>
                
                <div class="indicator-toggles">
                    <label><input type="checkbox" @bind="_chartConfig.ShowVwap" /> VWAP</label>
                    <label><input type="checkbox" @bind="_chartConfig.ShowEma9" /> EMA 9</label>
                    <label><input type="checkbox" @bind="_chartConfig.ShowEma21" /> EMA 21</label>
                    <label><input type="checkbox" @bind="_chartConfig.ShowRsi" /> RSI</label>
                    <label><input type="checkbox" @bind="_chartConfig.ShowMacd" /> MACD</label>
                </div>
            </div>
            
            <div id="chart-container" class="chart-container">
                @if (_isLoading)
                {
                    <div class="chart-loading">
                        <div class="spinner"></div>
                        <span>Loading chart data...</span>
                    </div>
                }
                else if (_chartData == null)
                {
                    <div class="chart-empty">
                        <span>📊 Enter a symbol to begin analysis</span>
                    </div>
                }
                else
                {
                    @* TradingView Lightweight Charts will be rendered here via JS *@
                    <div id="tv-chart"></div>
                }
            </div>
        </div>

        @* AI Advisor Panel (Bottom Half) *@
        <div class="advisor-panel">
            <div class="advisor-header">
                <h2>🤖 AI Advisor</h2>
                <div class="advisor-actions">
                    <button class="btn-analyze" @onclick="QuickAnalyzeAsync" disabled="@(_isAnalyzing || _indicators == null)">
                        @if (_isAnalyzing)
                        {
                            <span>⟳ Analyzing...</span>
                        }
                        else
                        {
                            <span>🔍 Quick Analysis</span>
                        }
                    </button>
                    <button class="btn-full-analysis" @onclick="FullAnalysisAsync" disabled="@(_isAnalyzing || _indicators == null)">
                        📊 Full Analysis
                    </button>
                </div>
            </div>
            
            <div class="advisor-content">
                @if (!string.IsNullOrEmpty(_aiSummary))
                {
                    <div class="ai-summary">
                        @((MarkupString)FormatAiResponse(_aiSummary))
                    </div>
                }
                
                @if (_aiAnalysis != null)
                {
                    <div class="analysis-grid">
                        <div class="analysis-section bullish">
                            <h3>📈 Bullish Signals</h3>
                            <ul>
                                @foreach (var signal in _aiAnalysis.BullishSignals)
                                {
                                    <li>@signal</li>
                                }
                            </ul>
                        </div>
                        
                        <div class="analysis-section bearish">
                            <h3>📉 Bearish Signals</h3>
                            <ul>
                                @foreach (var signal in _aiAnalysis.BearishSignals)
                                {
                                    <li>@signal</li>
                                }
                            </ul>
                        </div>
                    </div>
                    
                    @if (_aiAnalysis.Warnings.Count > 0)
                    {
                        <div class="warnings">
                            <h3>⚠️ Warnings</h3>
                            @foreach (var warning in _aiAnalysis.Warnings)
                            {
                                <div class="warning-item">@warning</div>
                            }
                        </div>
                    }
                }
            </div>
            
            @* Risk-Protected Trade Setup *@
            @if (_proposedSetup != null)
            {
                <div class="trade-setup-panel">
                    <h3>🎯 Trade Setup</h3>
                    
                    <div class="setup-details">
                        <div class="setup-row">
                            <span class="label">Direction:</span>
                            <span class="value @(_proposedSetup.IsLong ? "long" : "short")">
                                @(_proposedSetup.IsLong ? "📈 LONG" : "📉 SHORT")
                            </span>
                        </div>
                        <div class="setup-row">
                            <span class="label">Entry:</span>
                            <span class="value">$@_proposedSetup.EntryPrice.ToString("F2")</span>
                        </div>
                        <div class="setup-row">
                            <span class="label">Stop Loss:</span>
                            <span class="value stop">$@_proposedSetup.StopLoss.ToString("F2") 
                                (@_proposedSetup.StopLossPercent.ToString("F1")%)</span>
                        </div>
                        <div class="setup-row">
                            <span class="label">Take Profit:</span>
                            <span class="value target">$@_proposedSetup.TakeProfit.ToString("F2") 
                                (@_proposedSetup.TakeProfitPercent.ToString("F1")%)</span>
                        </div>
                        <div class="setup-row">
                            <span class="label">Quantity:</span>
                            <span class="value">@_proposedSetup.Quantity shares</span>
                        </div>
                    </div>
                    
                    <div class="risk-summary">
                        <div class="risk-item">
                            <span class="risk-label">Max Loss:</span>
                            <span class="risk-value loss">$@_proposedSetup.RiskDollars.ToString("F2")</span>
                        </div>
                        <div class="risk-item">
                            <span class="risk-label">Potential Gain:</span>
                            <span class="risk-value gain">$@_proposedSetup.RewardDollars.ToString("F2")</span>
                        </div>
                        <div class="risk-item">
                            <span class="risk-label">R:R Ratio:</span>
                            <span class="risk-value rr @(_proposedSetup.RiskRewardRatio >= 2 ? "good" : "")">
                                1:@_proposedSetup.RiskRewardRatio.ToString("F1")
                            </span>
                        </div>
                    </div>
                    
                    @if (_riskCheck != null && !_riskCheck.IsValid)
                    {
                        <div class="risk-errors">
                            <h4>⛔ Cannot Execute - Risk Limits Exceeded</h4>
                            @foreach (var error in _riskCheck.Errors)
                            {
                                <div class="risk-error">@error</div>
                            }
                        </div>
                    }
                    else
                    {
                        @if (_riskCheck?.Warnings.Count > 0)
                        {
                            <div class="risk-warnings">
                                @foreach (var warning in _riskCheck.Warnings)
                                {
                                    <div class="risk-warning">⚠️ @warning</div>
                                }
                            </div>
                        }

                        <div class="execute-section">
                            <button class="btn-execute @(_proposedSetup.IsLong ? "long" : "short")"
                                    @onclick="ExecuteTradeAsync">
                                🚀 Execute @(_proposedSetup.IsLong ? "LONG" : "SHORT") Trade
                            </button>
                            <p class="execute-disclaimer">
                                You will @(_proposedSetup.IsLong ? "BUY" : "SELL") @_proposedSetup.Quantity shares 
                                @@ $@(_proposedSetup.EntryPrice.ToString("F2")) with automatic SL/TP
                            </p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Symbol { get; set; }

    private string _symbolInput = "";
    private ChartConfig _chartConfig = new();
    private ChartBundle? _chartData;
    private IndicatorSnapshot? _indicators;
    private AiAnalysis? _aiAnalysis;
    private string _aiSummary = "";
    private TradeSetup? _proposedSetup;
    private RiskCheckResult? _riskCheck;
    private RiskLimits _riskLimits = new();

    private bool _isLoading;
    private bool _isAnalyzing;
    private bool _isJsReady;

    private List<GapperCandidate> _topGappers = [];

    protected override async Task OnInitializedAsync()
    {
        // Load top gappers for quick access
        _topGappers = Scanner.GetTopCandidates(10).ToList();

        if (!string.IsNullOrEmpty(Symbol))
        {
            _symbolInput = Symbol;
            // Don't load yet - wait for JS to be ready
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isJsReady = true;

            // Now load data if symbol was specified
            if (!string.IsNullOrEmpty(Symbol))
            {
                await LoadSymbolAsync();
                StateHasChanged();
            }
        }
    }

    private async Task OnSymbolKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await LoadSymbolAsync();
        }
    }

    private async Task LoadSymbolAsync()
    {
        if (string.IsNullOrWhiteSpace(_symbolInput)) return;

        Symbol = _symbolInput.ToUpperInvariant();
        _chartConfig.Symbol = Symbol;
        _isLoading = true;
        _aiAnalysis = null;
        _aiSummary = "";
        _proposedSetup = null;
        StateHasChanged();

        try
        {
            // Try to load real historical data first
            var intervalMinutes = int.TryParse(_chartConfig.Interval, out var i) ? i : 1;
            var candles = await HistoricalData.GetCandlesAsync(Symbol, DateTime.Today.AddDays(-30), DateTime.Now, intervalMinutes);

            // Fall back to sample data if no historical data available
            if (candles.Count == 0)
            {
                candles = GenerateSampleCandles(Symbol, 200);
            }

            _chartData = ChartService.PrepareChartData(candles, _chartConfig);

            // Build indicator snapshot from latest data
            _indicators = BuildIndicatorSnapshot(Symbol, candles, _chartData);

            // Render chart via JavaScript interop
            await RenderChartAsync();

            // Auto-generate trade setup based on indicators
            _proposedSetup = GenerateTradeSetup(_indicators);
            if (_proposedSetup != null)
            {
                _riskCheck = _riskLimits.ValidateTrade(_proposedSetup, 10000, 0);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading symbol: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }
    
    private void LoadSymbol(string symbol)
    {
        _symbolInput = symbol;
        _ = LoadSymbolAsync();
    }
    
    private void SetInterval(string interval)
    {
        _chartConfig.Interval = interval;
        _ = LoadSymbolAsync();
    }
    
    private async Task QuickAnalyzeAsync()
    {
        if (_indicators == null) return;
        
        _isAnalyzing = true;
        StateHasChanged();
        
        try
        {
            _aiSummary = await AiAdvisor.InterpretIndicatorsAsync(_indicators);
            _aiAnalysis = await AiAdvisor.AnalyzeSetupAsync(Symbol ?? "", _indicators, _proposedSetup);
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }
    
    private async Task FullAnalysisAsync()
    {
        if (_indicators == null) return;
        
        _isAnalyzing = true;
        StateHasChanged();
        
        try
        {
            _aiSummary = await AiAdvisor.FullScreenAnalysisAsync(Symbol ?? "", _indicators);
            _aiAnalysis = await AiAdvisor.AnalyzeSetupAsync(Symbol ?? "", _indicators, _proposedSetup);
        }
        finally
        {
            _isAnalyzing = false;
            StateHasChanged();
        }
    }
    
    private async Task ExecuteTradeAsync()
    {
        if (_proposedSetup == null || _riskCheck == null || !_riskCheck.IsValid) return;
        
        // TODO: Execute via Core backend
        Console.WriteLine($"Executing {_proposedSetup.Direction} trade for {_proposedSetup.Symbol}");
    }
    
    private async Task RenderChartAsync()
    {
        if (_chartData == null) return;

        try
        {
            // Initialize chart and set data
            await JS.InvokeVoidAsync("initializeChart", "chart-container", new { height = 400 });
            await JS.InvokeVoidAsync("setCandleData", _chartData.Candles);

            // Add overlays
            foreach (var overlay in _chartData.Overlays)
            {
                var shouldShow = overlay.Name switch
                {
                    "VWAP" => _chartConfig.ShowVwap,
                    "EMA 9" => _chartConfig.ShowEma9,
                    "EMA 21" => _chartConfig.ShowEma21,
                    _ => true
                };

                if (shouldShow && overlay.Points.Count > 0)
                {
                    var points = overlay.Points
                        .Where(p => p.Value > 0)
                        .Select(p => new { time = p.Time, value = p.Value })
                        .ToList();

                    if (points.Count > 0)
                    {
                        await JS.InvokeVoidAsync("addOverlay", overlay.Name, points, overlay.Color, overlay.LineWidth);
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Chart render error: {ex.Message}");
        }
    }
    
    // Helper methods
    private List<ChartDataPoint> GenerateSampleCandles(string symbol, int count)
    {
        var candles = new List<ChartDataPoint>();
        var random = new Random(symbol.GetHashCode());
        var basePrice = symbol switch
        {
            "NVDA" => 140.0,
            "AAPL" => 185.0,
            "TSLA" => 250.0,
            "SPY" => 500.0,
            _ => 50.0 + random.NextDouble() * 150
        };
        
        var price = basePrice;
        var now = DateTime.UtcNow;
        
        for (int i = count - 1; i >= 0; i--)
        {
            var time = now.AddMinutes(-i);
            var change = (random.NextDouble() - 0.48) * 0.5;  // Slight upward bias
            var open = price;
            var close = price * (1 + change / 100);
            var high = Math.Max(open, close) * (1 + random.NextDouble() * 0.002);
            var low = Math.Min(open, close) * (1 - random.NextDouble() * 0.002);
            var volume = (long)(random.NextDouble() * 100000 + 50000);
            
            candles.Add(new ChartDataPoint
            {
                Time = new DateTimeOffset(time).ToUnixTimeSeconds(),
                Open = Math.Round(open, 2),
                High = Math.Round(high, 2),
                Low = Math.Round(low, 2),
                Close = Math.Round(close, 2),
                Volume = volume
            });
            
            price = close;
        }
        
        return candles;
    }
    
    private IndicatorSnapshot BuildIndicatorSnapshot(string symbol, List<ChartDataPoint> candles, ChartBundle bundle)
    {
        var latest = candles.Last();
        var snapshot = new IndicatorSnapshot
        {
            Symbol = symbol,
            Price = latest.Close,
            Volume = latest.Volume,
            AverageVolume = candles.Average(c => c.Volume)
        };
        
        // Get indicator values from overlays
        foreach (var overlay in bundle.Overlays)
        {
            var lastPoint = overlay.Points.LastOrDefault();
            if (lastPoint.Value > 0)
            {
                if (overlay.Name == "VWAP") snapshot.Vwap = lastPoint.Value;
                else if (overlay.Name == "EMA 9") snapshot.Ema9 = lastPoint.Value;
                else if (overlay.Name == "EMA 21") snapshot.Ema21 = lastPoint.Value;
                else if (overlay.Name == "EMA 50") snapshot.Ema50 = lastPoint.Value;
            }
        }
        
        // Get oscillator values
        foreach (var osc in bundle.Oscillators)
        {
            if (osc.Name == "RSI")
            {
                var rsiLine = osc.Lines.FirstOrDefault(l => l.Name == "RSI");
                var lastRsi = rsiLine?.Points.LastOrDefault();
                if (lastRsi?.Value > 0) snapshot.Rsi = lastRsi.Value.Value;
            }
            else if (osc.Name == "MACD")
            {
                var macdLine = osc.Lines.FirstOrDefault(l => l.Name == "MACD");
                var signalLine = osc.Lines.FirstOrDefault(l => l.Name == "Signal");
                var histLine = osc.Lines.FirstOrDefault(l => l.Name == "Histogram");
                
                var lastMacd = macdLine?.Points.LastOrDefault();
                var lastSignal = signalLine?.Points.LastOrDefault();
                var lastHist = histLine?.Points.LastOrDefault();
                
                if (lastMacd != null) snapshot.MacdLine = lastMacd.Value.Value;
                if (lastSignal != null) snapshot.SignalLine = lastSignal.Value.Value;
                if (lastHist != null) snapshot.Histogram = lastHist.Value.Value;
            }
        }
        
        // Simulate ADX (would be calculated from real data)
        snapshot.Adx = 25 + new Random().NextDouble() * 30;
        snapshot.PlusDI = 20 + new Random().NextDouble() * 20;
        snapshot.MinusDI = 15 + new Random().NextDouble() * 20;
        
        return snapshot;
    }
    
    private TradeSetup? GenerateTradeSetup(IndicatorSnapshot indicators)
    {
        var score = indicators.CalculateMarketScore();
        if (Math.Abs(score) < 30) return null;  // Too uncertain
        
        var isLong = score > 0;
        var price = indicators.Price;
        
        // Calculate stop/target based on indicators
        var stopPercent = indicators.Adx > 30 ? 2.0 : 2.5;  // Tighter in trending market
        var targetMultiplier = 2.5;
        
        var stop = isLong ? price * (1 - stopPercent / 100) : price * (1 + stopPercent / 100);
        var target = isLong 
            ? price + (price - stop) * targetMultiplier 
            : price - (stop - price) * targetMultiplier;
        
        var riskPerShare = Math.Abs(price - stop);
        var quantity = riskPerShare > 0 ? (int)Math.Floor(50.0 / riskPerShare) : 1;
        quantity = Math.Max(1, quantity);
        
        return new TradeSetup
        {
            Symbol = indicators.Symbol,
            Direction = isLong ? TradeDirection.Long : TradeDirection.Short,
            EntryPrice = Math.Round(price, 2),
            StopLoss = Math.Round(stop, 2),
            TakeProfit = Math.Round(target, 2),
            TrailingStopPercent = 1.5,
            Quantity = quantity,
            RiskDollars = Math.Round(quantity * riskPerShare, 2),
            RewardDollars = Math.Round(quantity * Math.Abs(target - price), 2),
            ConfidenceScore = Math.Abs(score),
            Rationale = $"Market score {score} suggests {(isLong ? "bullish" : "bearish")} bias"
        };
    }
    
    private string GetScoreClass(int score) => score switch
    {
        >= 70 => "very-bullish",
        >= 30 => "bullish",
        >= -30 => "neutral",
        >= -70 => "bearish",
        _ => "very-bearish"
    };
    
    private string FormatAiResponse(string response)
    {
        // Convert markdown-like formatting to HTML
        return response
            .Replace("**", "<strong>")
            .Replace("\n\n", "</p><p>")
            .Replace("\n- ", "<br/>• ")
            .Replace("\n", "<br/>");
    }

    public async ValueTask DisposeAsync()
    {
        if (_isJsReady)
        {
            try
            {
                await JS.InvokeVoidAsync("destroyChart");
            }
            catch (JSDisconnectedException)
            {
                // Circuit disconnected, ignore
            }
        }
    }
}
