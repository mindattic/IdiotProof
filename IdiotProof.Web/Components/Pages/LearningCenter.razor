@page "/learning-center"
@page "/learn"
@page "/docs"
@page "/documentation"
@page "/help"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

<PageTitle>Learning Center - IdiotProof</PageTitle>

<div class="learning-center-page" data-meta="Documentation and help center for IdiotProof trading system">
    <header class="learning-center-header">
        <h1>📖 Learning Center</h1>
        <p class="subtitle">Trading terminology, application features, and technical reference</p>

        <div class="header-controls">
            <input type="text" class="search-input" placeholder="🔍 Search documentation..." 
                   @bind="_searchTerm" @bind:event="oninput" />
            <select class="section-filter" @bind="_selectedSection">
                <option value="">All Sections</option>
                <option value="quickstart">Quick Start</option>
                <option value="trading">Trading Terms</option>
                <option value="features">App Features</option>
                <option value="orders">Order Types</option>
                <option value="indicators">Indicators</option>
                <option value="scoring">Scoring System</option>
                <option value="breakout">Breakout-Pullback Strategy</option>
            </select>
        </div>
    </header>

    <div class="learning-center-sections">
        @* Quick Start Guide *@
        @if (ShouldShowSection("quickstart"))
        {
            <section class="learning-center-section quickstart" data-analysis="Quick start guide for new users">
                <h2>🚀 Quick Start Guide</h2>

                <div class="guide-card" data-meta="Step 1: Connect to IBKR for live trading">
                    <h3>1. Connect Your Broker</h3>
                    <p>Start the <strong>IdiotProof.Core</strong> application first. It connects to Interactive Brokers TWS/Gateway.</p>
                    <div class="code-block">
                        <code>cd IdiotProof.Core && dotnet run</code>
                    </div>
                    <p class="note">Ensure TWS is running with API connections enabled on port 7497 (paper) or 7496 (live).</p>
                </div>

                <div class="guide-card" data-meta="Step 2: Launch the web interface">
                    <h3>2. Open the Dashboard</h3>
                    <p>The web interface runs at <code>http://localhost:5000</code>. The Dashboard shows:</p>
                    <ul>
                        <li>Live gapper candidates with confidence scores</li>
                        <li>Your current positions and P&L</li>
                        <li>Quick trade buttons for one-click execution</li>
                    </ul>
                </div>

                <div class="guide-card" data-meta="Step 3: Execute your first trade">
                    <h3>3. Execute a Trade</h3>
                    <ol>
                        <li>Find a high-confidence gapper (Grade A or B)</li>
                        <li>Click <strong>LONG</strong> (expecting rise) or <strong>SHORT</strong> (expecting fall)</li>
                        <li>System auto-calculates stop loss and take profit</li>
                        <li>Confirm the bracket order</li>
                    </ol>
                </div>

                <div class="guide-card" data-meta="Step 4: Monitor with AI assistance">
                    <h3>4. Use the AI Advisor</h3>
                    <p>Click 📸 in the AI Advisor panel to capture and analyze any screen. The AI provides:</p>
                    <ul>
                        <li>Interpretation of what you're seeing</li>
                        <li>Key observations and patterns</li>
                        <li>Actionable trading insights</li>
                        <li>Risk warnings</li>
                    </ul>
                </div>
            </section>
        }

        @* Scoring System Documentation *@
        @if (ShouldShowSection("scoring"))
        {
            <section class="learning-center-section scoring" data-analysis="Documentation of how confidence and market scores are calculated">
                <h2>📊 Scoring System</h2>

                <div class="scoring-card" data-meta="Gapper Confidence Score: Weighted combination of gap size, volume, momentum, and source confirmation">
                    <h3>Gapper Confidence Score (0-100)</h3>
                    <table class="scoring-table">
                        <thead>
                            <tr>
                                <th>Factor</th>
                                <th>Weight</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr data-analysis="Gap size factor: Larger gaps indicate stronger catalyst/momentum">
                                <td>Gap Size</td>
                                <td>30%</td>
                                <td>5%+ gap = max points. Larger gaps = stronger momentum.</td>
                            </tr>
                            <tr data-analysis="Volume factor: Higher premarket volume confirms the move">
                                <td>Volume</td>
                                <td>30%</td>
                                <td>Premarket volume vs daily average. 3x+ = max points.</td>
                            </tr>
                            <tr data-analysis="Momentum factor: Is price building or fading from gap high?">
                                <td>Momentum</td>
                                <td>25%</td>
                                <td>Is price holding/building or fading? Near gap high = bullish.</td>
                            </tr>
                            <tr data-analysis="Multi-source factor: Confirmation from multiple scanners">
                                <td>Multi-Source</td>
                                <td>15%</td>
                                <td>Detected by 2+ scanners = higher reliability.</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="grade-legend">
                        <span class="grade grade-a" data-meta="Grade A: 80-100%. High conviction setup.">A: 80-100%</span>
                        <span class="grade grade-b" data-meta="Grade B: 65-79%. Good setup, worth watching.">B: 65-79%</span>
                        <span class="grade grade-c" data-meta="Grade C: 50-64%. Moderate, needs confirmation.">C: 50-64%</span>
                        <span class="grade grade-d" data-meta="Grade D: 35-49%. Weak, higher risk.">D: 35-49%</span>
                        <span class="grade grade-f" data-meta="Grade F: 0-34%. Not a real gapper.">F: 0-34%</span>
                    </div>
                </div>

                <div class="scoring-card" data-meta="Market Score: Technical indicator analysis (-100 to +100)">
                    <h3>Market Score (-100 to +100)</h3>
                    <p>Used by AutonomousTrading and AdaptiveOrder to make entry/exit decisions.</p>
                    <table class="scoring-table">
                        <thead>
                            <tr>
                                <th>Indicator</th>
                                <th>Weight</th>
                                <th>Bullish Signal</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr data-analysis="VWAP: Institutional level. Above = bullish bias">
                                <td>VWAP Position</td>
                                <td>15%</td>
                                <td>Price above VWAP = positive score</td>
                            </tr>
                            <tr data-analysis="EMA Stack: Trend direction from moving averages">
                                <td>EMA Stack</td>
                                <td>20%</td>
                                <td>Price > EMA 9 > EMA 21 = strong bullish</td>
                            </tr>
                            <tr data-analysis="RSI: Overbought/oversold momentum">
                                <td>RSI</td>
                                <td>15%</td>
                                <td>30-70 range positive, extremes negative</td>
                            </tr>
                            <tr data-analysis="MACD: Momentum direction and strength">
                                <td>MACD</td>
                                <td>20%</td>
                                <td>MACD > Signal + rising histogram</td>
                            </tr>
                            <tr data-analysis="ADX: Trend strength with directional movement">
                                <td>ADX + DI</td>
                                <td>20%</td>
                                <td>ADX > 25 with +DI > -DI</td>
                            </tr>
                            <tr data-analysis="Volume: Confirms price direction">
                                <td>Volume</td>
                                <td>10%</td>
                                <td>High volume + above VWAP = bullish</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>
        }

        @* Trading Terminology *@
        @if (ShouldShowSection("trading"))
        {
            <section class="learning-center-section" data-analysis="Trading terminology definitions">
                <h2>📈 Trading Terminology</h2>

                @foreach (var term in TradingTerms.Where(t => MatchesSearch(t)))
                {
                    <div class="learning-center-item" data-meta="@term.Term: @term.Definition">
                        <h3>@term.Term</h3>
                        <p>@term.Definition</p>
                        @if (!string.IsNullOrEmpty(term.Example))
                        {
                            <div class="example">
                                <strong>Example:</strong> @term.Example
                            </div>
                        }
                    </div>
                }
            </section>
        }

        @* Application Features *@
        @if (ShouldShowSection("features"))
        {
            <section class="learning-center-section" data-analysis="Application features documentation">
                <h2>🔧 Application Features</h2>

                @foreach (var feature in AppFeatures.Where(f => MatchesSearch(f)))
                {
                    <div class="learning-center-item" data-meta="@feature.Term: @feature.Definition">
                        <h3>@feature.Term</h3>
                        <p>@feature.Definition</p>
                        @if (!string.IsNullOrEmpty(feature.Example))
                        {
                            <div class="example">
                                <strong>How to use:</strong> @feature.Example
                            </div>
                        }
                    </div>
                }
            </section>
        }

        @* Order Types *@
        @if (ShouldShowSection("orders"))
        {
            <section class="learning-center-section" data-analysis="Order types documentation">
                <h2>📋 Order Types</h2>

                @foreach (var order in OrderTypes.Where(o => MatchesSearch(o)))
                {
                    <div class="learning-center-item" data-meta="@order.Term: @order.Definition">
                        <h3>@order.Term</h3>
                        <p>@order.Definition</p>
                        @if (!string.IsNullOrEmpty(order.Example))
                        {
                            <div class="example">
                                <strong>Example:</strong> @order.Example
                            </div>
                        }
                    </div>
                }
            </section>
        }

        @* Technical Indicators *@
        @if (ShouldShowSection("indicators"))
        {
            <section class="learning-center-section" data-analysis="Technical indicators documentation">
                <h2>📊 Technical Indicators</h2>

                @foreach (var indicator in Indicators.Where(i => MatchesSearch(i)))
                {
                    <div class="learning-center-item" data-meta="@indicator.Term: @indicator.Definition">
                        <h3>@indicator.Term</h3>
                        <p>@indicator.Definition</p>
                        @if (!string.IsNullOrEmpty(indicator.Example))
                        {
                            <div class="example">
                                <strong>Usage:</strong> @indicator.Example
                            </div>
                        }
                    </div>
                }
            </section>
        }

        @* Breakout-Pullback Strategy System *@
        @if (ShouldShowSection("breakout"))
        {
            <section class="learning-center-section breakout-strategy" data-analysis="Complete breakout-pullback strategy system documentation">
                <h2>🎯 Breakout-Pullback Strategy System</h2>

                <div class="strategy-intro" data-meta="The 'No Break, No Trade' methodology for high-probability entries">
                    <p><strong>"No Break, No Trade"</strong> - The system waits for a confirmed breakout and pullback before entry, avoiding FOMO trades and chasing.</p>
                </div>

                <div class="guide-card" data-meta="The breakout-pullback pattern explained">
                    <h3>📈 The Pattern</h3>
                    <pre class="pattern-diagram">
      Price
        │         *** (HOD)
        │        *   *
        │       *     * ←── PULLBACK
        │      *       *
   ═════│═════*═════════*════════ TRIGGER LEVEL
        │    *           * ←── BOUNCE (Entry)
        │   *            
   ─────│──*────────────────────── SUPPORT/VWAP
        │ *             
        │*____________________________________________ Time
           │        │         │
         Break   Pullback  Confirm
                    </pre>
                    <ol>
                        <li><strong>TRIGGER:</strong> Price breaks above resistance level</li>
                        <li><strong>DON'T CHASE:</strong> Wait for pullback toward breakout level</li>
                        <li><strong>CONFIRMATION:</strong> Price holds support (VWAP + key level)</li>
                        <li><strong>ENTRY:</strong> On confirmed bounce from support zone</li>
                        <li><strong>SCALE OUT:</strong> T1 (quick scalp), T2 (main target), T3 (runner)</li>
                    </ol>
                </div>

                <div class="guide-card" data-meta="Setup state machine - how setups progress through states">
                    <h3>🔄 Setup State Machine</h3>
                    <pre class="state-diagram">
    👀 WATCHING ──▶ 🚀 TRIGGERED ──▶ ↩️ PULLBACK ──▶ ✅ CONFIRMED ──▶ 📈 ENTERED ──▶ 🎯 COMPLETED
         │               │                │               │              │
         │               ▼                ▼               ▼              ▼
         └─────────▶ ❌ INVALIDATED ◀────┴───────────────┴──────────────┘
                   (Pattern failed - NO TRADE)
                    </pre>
                    <table class="state-table">
                        <tr><td>👀 <strong>WATCHING</strong></td><td>Monitoring for price to break above trigger</td></tr>
                        <tr><td>🚀 <strong>TRIGGERED</strong></td><td>Breakout occurred! Waiting for pullback</td></tr>
                        <tr><td>↩️ <strong>PULLBACK</strong></td><td>Price pulling back - watching support</td></tr>
                        <tr><td>✅ <strong>CONFIRMED</strong></td><td>Ready for entry! Pullback held support</td></tr>
                        <tr><td>📈 <strong>ENTERED</strong></td><td>Position active - monitoring targets</td></tr>
                        <tr><td>🎯 <strong>COMPLETED</strong></td><td>All targets hit or manually closed</td></tr>
                        <tr><td>❌ <strong>INVALIDATED</strong></td><td>Support broke - pattern failed</td></tr>
                    </table>
                </div>

                <div class="guide-card" data-meta="Multi-target exit strategy for scaling out">
                    <h3>💰 Multi-Target Exit Strategy</h3>
                    <table class="target-table">
                        <tr>
                            <th>Target</th>
                            <th>% to Sell</th>
                            <th>Purpose</th>
                            <th>Stop Action</th>
                        </tr>
                        <tr data-meta="T1: Quick scalp to lock in profits early">
                            <td><strong>T1</strong></td>
                            <td>40%</td>
                            <td>Quick scalp - secure profits</td>
                            <td>Move stop to breakeven</td>
                        </tr>
                        <tr data-meta="T2: Main target - where most profit comes from">
                            <td><strong>T2</strong></td>
                            <td>40%</td>
                            <td>Main target - primary profit</td>
                            <td>Move stop to T1 level</td>
                        </tr>
                        <tr data-meta="T3: Runner - let the rest ride for extended moves">
                            <td><strong>T3</strong></td>
                            <td>20%</td>
                            <td>Runner - capture extended move</td>
                            <td>Trailing stop</td>
                        </tr>
                    </table>
                </div>

                <div class="guide-card" data-meta="Scanning criteria for qualified setups">
                    <h3>🔍 Scanning Criteria</h3>
                    <p>The PremarketSetupScanner filters for these conditions:</p>
                    <ul>
                        <li><strong>Price:</strong> $0.30 - $25.00 (small caps, more volatile)</li>
                        <li><strong>Gap:</strong> 3%+ from previous close</li>
                        <li><strong>Volume:</strong> 1.5x average volume ratio</li>
                        <li><strong>Confidence:</strong> 60+ score to qualify</li>
                    </ul>
                </div>

                <div class="guide-card" data-meta="Example IdiotScript for breakout-pullback">
                    <h3>📝 IdiotScript Example</h3>
                    <pre class="code-block">
Ticker(ERNA)
    .Name("ERNA AH Momentum")
    .Session(IS.PREMARKET)
    .Breakout(0.52)          // Wait for break above $0.52
    .Pullback()              // Wait for pullback
    .IsAboveVwap()           // Must hold VWAP (dynamic support)
    .HoldsAbove(0.48)        // AND must hold above $0.48 (static)
    .Long()
    .TakeProfit(0.66, 0.88)  // T1: $0.66 (27%), T2: $0.88 (69%)
    .StopLoss(0.46)          // Below $0.48 invalidation
    .Repeat()                // Re-enter after exit
                    </pre>
                </div>
            </section>
        }
    </div>
</div>

@code {
    private string _searchTerm = "";
    private string _selectedSection = "";

    private bool MatchesSearch(LearningEntry entry)
    {
        if (string.IsNullOrWhiteSpace(_searchTerm)) return true;
        return entry.Term.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
               entry.Definition.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase);
    }

    private bool ShouldShowSection(string section)
    {
        // Show all if no filter or if search is active
        if (string.IsNullOrEmpty(_selectedSection) || !string.IsNullOrWhiteSpace(_searchTerm))
            return true;
        return _selectedSection == section;
    }

    private record LearningEntry(string Term, string Definition, string? Example = null);

    private static readonly LearningEntry[] TradingTerms =
    [
        new("Gap Up", "When a stock opens significantly higher than its previous day's close, creating a 'gap' in the price chart.", "NVDA closes at $140, opens at $148 = 5.7% gap up"),
        new("Gap Down", "When a stock opens significantly lower than its previous day's close.", "AAPL closes at $180, opens at $172 = 4.4% gap down"),
        new("Premarket", "Trading session before regular market hours (4:00 AM - 9:30 AM ET). Lower volume, wider spreads.", null),
        new("RTH (Regular Trading Hours)", "The main trading session from 9:30 AM to 4:00 PM ET when most volume occurs.", null),
        new("After Hours", "Trading session after market close (4:00 PM - 8:00 PM ET).", null),
        new("Long Position", "Buying a stock expecting it to rise in price. You profit when price goes up.", "Buy 100 TSLA at $200, sell at $210 = $1,000 profit"),
        new("Short Position", "Borrowing and selling a stock expecting it to fall. You profit when price goes down.", "Short 50 NVDA at $150, cover at $140 = $500 profit"),
        new("Entry Price", "The price at which you open a position (buy for long, sell for short).", null),
        new("Stop Loss (SL)", "An order to automatically exit a position if price moves against you by a set amount, limiting losses.", "Buy at $100, set SL at $95 = max loss of $5/share"),
        new("Take Profit (TP)", "An order to automatically exit a position when price reaches your target profit level.", "Buy at $100, set TP at $110 = lock in $10/share profit"),
        new("Trailing Stop", "A stop loss that moves with price, locking in profits while allowing room for the trade to run.", "1.5% trailing: Price hits $110, stop moves to $108.35"),
        new("Risk:Reward Ratio (R:R)", "The potential reward divided by potential risk. A 1:2.5 means risking $1 to make $2.50.", "Entry $100, SL $98, TP $105 = Risk $2, Reward $5 = 1:2.5"),
        new("Position Size", "The number of shares you trade, calculated based on your risk tolerance.", null),
        new("VWAP", "Volume Weighted Average Price - the average price weighted by volume. Used as support/resistance.", null),
        new("HOD/LOD", "High of Day / Low of Day - the highest and lowest prices reached during the trading session.", null),
        new("Breakout", "When price moves above resistance or below support with increased volume.", null),
        new("Pullback", "A temporary price decline during an uptrend, often a buying opportunity.", null),
        new("Fade", "Trading against the prevailing move, expecting a reversal.", "Stock gaps up 10%, you short expecting it to come back down"),
        new("Bracket Order", "A set of orders including entry, stop loss, and take profit that execute together.", null),
    ];

    private static readonly LearningEntry[] AppFeatures =
    [
        new("Dashboard", "Main screen showing top gapping stocks with confidence scores and quick trade setups.", "Click any gapper row to see calculated entry/exit points"),
        new("Gapper Scanner", "Aggregates data from multiple sources (Finviz, Barchart, StockAnalysis, TradingView) to find stocks gapping significantly.", null),
        new("Confidence Score", "A 0-100% rating based on gap size, volume, and multi-source confirmation.", "80%+ = High confidence, 60-79% = Medium, <60% = Low"),
        new("Quick Trade", "Pre-calculated trade setups with entry, stop loss, take profit, and position sizing.", null),
        new("Execute Trade", "Places a bracket order (entry + SL + TP) through IBKR with one click.", null),
        new("Trade Page", "Advanced trading interface with chart and AI analysis.", "Enter symbol and click Analyze for insights"),
        new("Analyze Page", "Deep technical analysis with market score and AI recommendations.", null),
        new("Market Score", "A -100 to +100 score based on VWAP, EMA, RSI, MACD, ADX, and volume indicators.", "+70 = Very bullish, -70 = Very bearish"),
        new("Backtest", "Replay historical data with simulated trades to test strategies.", "Select symbol and date to see how a strategy would have performed"),
