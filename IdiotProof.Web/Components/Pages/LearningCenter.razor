    ];

    private static readonly LearningEntry[] OrderTypes =
    [
        new("Market Order", "Executes immediately at the best available price. Fast but may slip in volatile markets.", null),
        new("Limit Order", "Only executes at your specified price or better. Guarantees price but may not fill.", "Limit buy at $99.50 when price is $100 = wait for dip"),
        new("Stop Order", "Triggers a market order when price hits your stop level. Used for stop losses.", null),
