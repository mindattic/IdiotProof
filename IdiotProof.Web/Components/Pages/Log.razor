@page "/log"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using IdiotProof.Web.Services
@inject GlobalLogService LogService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Log - IdiotProof</PageTitle>

<div class="log-container" data-meta="System log viewer - real-time messages from Core engine including trades, orders, alerts, and AI insights">
    <div class="log-toolbar" data-analysis="@LogService.Logs.Count total logs. Filter by category or search text. Auto-scroll @(AutoScroll ? "enabled" : "disabled").">
        <div class="connection-indicator @(LogService.IsConnected ? "connected" : "disconnected")"
             data-meta="@(LogService.IsConnected ? "Connected to Core - receiving real-time logs" : "Waiting for Core connection")">
            @(LogService.IsConnected ? "● Connected" : "○ Connecting...")
        </div>
        <button class="log-filter-btn @GetFilterClass(null)" @onclick="@(() => SetFilter(null))" data-meta="Show all log categories">All</button>
        <button class="log-filter-btn @GetFilterClass("Trade")" @onclick="@(() => SetFilter("Trade"))" data-meta="Filter: Trade executions and position changes">Trades</button>
        <button class="log-filter-btn @GetFilterClass("Order")" @onclick="@(() => SetFilter("Order"))" data-meta="Filter: Order submissions, fills, and cancellations">Orders</button>
        <button class="log-filter-btn @GetFilterClass("Alert")" @onclick="@(() => SetFilter("Alert"))" data-meta="Filter: Price alerts and sudden move detections">Alerts</button>
        <button class="log-filter-btn @GetFilterClass("Connection")" @onclick="@(() => SetFilter("Connection"))" data-meta="Filter: IBKR connection status and errors">Connection</button>
        <button class="log-filter-btn @GetFilterClass("AI")" @onclick="@(() => SetFilter("AI"))" data-meta="Filter: AI advisor insights and recommendations">AI</button>

        <input type="text" class="log-search" placeholder="🔍 Search logs..." @bind="SearchText" @bind:event="oninput" 
               data-meta="Search within log messages. Filters by content or symbol." />

        <button class="log-filter-btn" @onclick="ClearLogs" title="Clear all logs" data-meta="Clear log display (does not affect Core)">🗑️ Clear</button>
        <button class="log-filter-btn" @onclick="ToggleAutoScroll" title="Toggle auto-scroll"
                data-meta="@(AutoScroll ? "Auto-scroll ON: New logs scroll into view" : "Auto-scroll OFF: Manual scroll mode")">
            @(AutoScroll ? "📜 Auto" : "⏸️ Manual")
        </button>
        <span class="log-count">@LogService.Logs.Count logs</span>
    </div>

    <div class="log-entries" @ref="logEntriesRef" data-analysis="Log entries filtered by: @(ActiveFilter ?? "All"). @FilteredLogs.Count() visible.">
        @if (!FilteredLogs.Any())
        {
            <div class="log-empty">
                <div class="log-empty-icon">📋</div>
                <div>No log entries yet</div>
                <div style="font-size: 12px; margin-top: 8px;">Waiting for Core to send messages...</div>
            </div>
        }
        else
        {
            @foreach (var log in FilteredLogs)
            {
                <div class="log-entry" data-level="@log.Level" @onclick="() => CopyToChat(log)"
                     data-analysis="[@log.Timestamp.ToString("HH:mm:ss")] @log.Category: @(log.Message.Length > 100 ? log.Message.Substring(0, 100) + "..." : log.Message)">
                    <span class="log-timestamp">@FormatTimestamp(log.Timestamp)</span>
                    <span class="log-category" data-category="@log.Category" data-meta="Category: @log.Category">@log.Category</span>
                    <span class="log-content">
                        @if (!string.IsNullOrEmpty(log.HtmlContent))
                        {
                            @((MarkupString)log.HtmlContent)
                        }
                        else
                        {
                            @log.Message
                        }
                    </span>
                    <button class="log-copy-btn" @onclick:stopPropagation="true" @onclick="() => CopyToClipboard(log)"
                            data-meta="Copy log entry to clipboard">
                        📋 Copy
                    </button>
                </div>
            }
        }
    </div>
</div>

@code {
    private ElementReference logEntriesRef;
    private string? ActiveFilter { get; set; }
    private string SearchText { get; set; } = "";
    private bool AutoScroll { get; set; } = true;

    private IEnumerable<LogEntry> FilteredLogs => LogService.Logs
        .Where(l => ActiveFilter == null || l.Category == ActiveFilter)
        .Where(l => string.IsNullOrEmpty(SearchText) || 
                    l.Message.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ||
                    (l.Symbol?.Contains(SearchText, StringComparison.OrdinalIgnoreCase) ?? false))
        .OrderByDescending(l => l.Timestamp);

    private string GetFilterClass(string? filter) => ActiveFilter == filter ? "active" : "";

    protected override void OnInitialized()
    {
        // Subscribe to log updates from the global service
        LogService.OnLogReceived += OnLogReceived;
    }

    private async void OnLogReceived()
    {
        await InvokeAsync(StateHasChanged);

        if (AutoScroll)
        {
            await ScrollToBottom();
        }
    }

    private void SetFilter(string? filter)
    {
        ActiveFilter = filter;
    }

    private void ClearLogs()
    {
        LogService.ClearLogs();
    }

    private void ToggleAutoScroll()
    {
        AutoScroll = !AutoScroll;
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await JS.InvokeVoidAsync("eval", "document.querySelector('.log-entries')?.scrollTo({top: 0, behavior: 'smooth'})");
        }
        catch { }
    }

    private async Task CopyToClipboard(LogEntry log)
    {
        var text = $"[{FormatTimestamp(log.Timestamp)}] [{log.Category}] {log.Message}";
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch { }
    }

    private async Task CopyToChat(LogEntry log)
    {
        var text = log.Message;
        if (!string.IsNullOrEmpty(log.Symbol))
        {
            text = $"[{log.Symbol}] {text}";
        }
        try
        {
            // Copy to clipboard as fallback if copyToChat doesn't exist
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
        catch { }
    }

    private static string FormatTimestamp(long timestamp)
    {
        var dt = DateTimeOffset.FromUnixTimeMilliseconds(timestamp).ToLocalTime();
        return dt.ToString("HH:mm:ss.fff");
    }

    public void Dispose()
    {
        LogService.OnLogReceived -= OnLogReceived;
    }
}
