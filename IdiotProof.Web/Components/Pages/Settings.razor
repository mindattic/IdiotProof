@page "/settings"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using IdiotProof.Shared.Settings
@using IdiotProof.Web.Services.Settings
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@inject SettingsProvider SettingsProvider
@inject IJSRuntime JS

<PageTitle>Settings - IdiotProof</PageTitle>

<div class="settings-page" data-meta="Application settings configuration - customize IdiotProof behavior, risk limits, and connections">
    <header class="settings-header">
        <div class="header-left">
            <h1>⚙️ Application Settings</h1>
            <span class="subtitle">Configure IdiotProof behavior and connections</span>
        </div>

        <div class="header-actions" data-analysis="@(_hasChanges ? "Unsaved changes pending. Click Save to apply." : "No pending changes.")">
            <div class="search-box" data-meta="Search across all settings by name or description">
                <span class="search-icon">🔍</span>
                <input type="text" 
                       placeholder="Search settings..." 
                       @bind="_searchQuery" 
                       @bind:event="oninput"
                       @bind:after="OnSearchChanged" />
                @if (!string.IsNullOrEmpty(_searchQuery))
                {
                    <button class="clear-search" @onclick="ClearSearch">✕</button>
                }
            </div>
            <label class="btn-secondary import-btn" data-meta="Import settings from JSON file">
                📤 Import
                <InputFile OnChange="ImportSettings" accept=".json" style="display:none" />
            </label>
            <button class="btn-secondary" @onclick="ExportSettings" title="Export settings to JSON"
                    data-meta="Download current settings as JSON for backup or sharing">
                📥 Export
            </button>
            <button class="btn-secondary" @onclick="ResetAllToDefaults" title="Reset all to defaults"
                    data-meta="Reset all settings to factory defaults. Cannot be undone.">
                🔄 Reset All
            </button>
            <button class="btn-primary" @onclick="SaveSettings" disabled="@(!_hasChanges)"
                    data-meta="@(_hasChanges ? "Save pending changes to disk" : "No changes to save")">
                💾 Save Changes
            </button>
        </div>
    </header>

    <div class="settings-layout">
        <aside class="settings-nav">
            @if (!_isSearching)
            {
                <nav>
                    @foreach (var category in _settingsBundle?.Categories ?? [])
                    {
                        <button class="nav-item @(_selectedCategory == category ? "active" : "")"
                                @onclick="() => SelectCategory(category)">
                            <span class="nav-icon">@GetCategoryIcon(category)</span>
                            <span class="nav-text">@category</span>
                            @if (GetCategoryChangeCount(category) > 0)
                            {
                                <span class="change-badge">@GetCategoryChangeCount(category)</span>
                            }
                        </button>
                    }
                </nav>
            }
            else
            {
                <div class="search-results-info">
                    <span class="search-count">@_filteredSettings.Count() results</span>
                    <span class="search-hint">for "@_searchQuery"</span>
                </div>
            }

            <div class="nav-footer">
                <div class="last-modified">
                    Last modified: @(_settingsBundle?.LastModified.ToLocalTime().ToString("g") ?? "N/A")
                </div>
            </div>
        </aside>

        <main class="settings-content">
            @if (_isSearching)
            {
                <div class="category-header">
                    <h2>🔍 Search Results</h2>
                    <p class="category-description">Found @_filteredSettings.Count() settings matching "@_searchQuery"</p>
                </div>

                <div class="settings-grid">
                    @foreach (var setting in _filteredSettings)
                    {
                        <div class="setting-card @(IsChanged(setting.Key) ? "changed" : "") @(setting.IsReadOnly ? "readonly" : "")">
                            <div class="setting-header">
                                <label class="setting-label" for="@setting.Key">@setting.DisplayName</label>
                                <span class="setting-category-tag">@setting.Category</span>
                                @if (setting.RequiresRestart)
                                {
                                    <span class="restart-badge" title="Requires app restart">🔄</span>
                                }
                                @if (setting.IsReadOnly)
                                {
                                    <span class="readonly-badge" title="Read-only (const)">🔒</span>
                                }
                            </div>

                            <div class="setting-control">
                                @RenderControl(setting)
                            </div>

                            @if (!string.IsNullOrEmpty(setting.Description))
                            {
                                <div class="setting-description">@HighlightSearchTerm(setting.Description)</div>
                            }
                        </div>
                    }
                </div>
            }
            else if (_settingsBundle != null && !string.IsNullOrEmpty(_selectedCategory))
            {
                <div class="category-header">
                    <h2>@GetCategoryIcon(_selectedCategory) @_selectedCategory</h2>
                    <p class="category-description">@GetCategoryDescription(_selectedCategory)</p>
                </div>
                
                <div class="settings-grid">
                    @foreach (var setting in _settingsBundle.GetByCategory(_selectedCategory))
                    {
                        <div class="setting-card @(IsChanged(setting.Key) ? "changed" : "") @(setting.IsReadOnly ? "readonly" : "")">
                            <div class="setting-header">
                                <label class="setting-label" for="@setting.Key">@setting.DisplayName</label>
                                @if (setting.RequiresRestart)
                                {
                                    <span class="restart-badge" title="Requires app restart">🔄</span>
                                }
                                @if (setting.IsReadOnly)
                                {
                                    <span class="readonly-badge" title="Read-only (const)">🔒</span>
                                }
                            </div>
                            
                            <div class="setting-control">
                                @RenderControl(setting)
                            </div>
                            
                            @if (!string.IsNullOrEmpty(setting.Description))
                            {
                                <div class="setting-description">@setting.Description</div>
                            }
                            
                            @if (IsChanged(setting.Key))
                            {
                                <div class="setting-change-indicator">
                                    <span>Changed from: @GetOriginalValue(setting.Key)</span>
                                    <button class="btn-reset-single" @onclick="() => ResetSetting(setting.Key)">↩️ Revert</button>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </main>
    </div>
    
    @if (_showSaveConfirm)
    {
        <div class="save-toast @(_importSuccess ? "import" : "")">
            @(_importSuccess ? "📤 Settings imported successfully" : "✅ Settings saved successfully")
        </div>
    }
</div>

@code {
    private SettingsBundle? _settingsBundle;
    private string _selectedCategory = "";
    private Dictionary<string, object?> _originalValues = new();
    private Dictionary<string, object?> _currentValues = new();
    private bool _hasChanges;
    private bool _showSaveConfirm;
    private bool _importSuccess;

    // Search
    private string _searchQuery = "";
    private bool _isSearching => !string.IsNullOrWhiteSpace(_searchQuery);
    private IEnumerable<SettingDefinition> _filteredSettings = [];

    protected override void OnInitialized()
    {
        LoadSettings();
    }

    private void LoadSettings()
    {
        _settingsBundle = SettingsProvider.GetAllSettings();

        // Store original values
        _originalValues.Clear();
        _currentValues.Clear();

        foreach (var setting in _settingsBundle.Settings)
        {
            _originalValues[setting.Key] = setting.Value;
            _currentValues[setting.Key] = setting.Value;
        }

        // Select first category
        if (_settingsBundle.Categories.Any())
        {
            _selectedCategory = _settingsBundle.Categories.First();
        }
    }
    
    private void SelectCategory(string category)
    {
        _selectedCategory = category;
    }
    
    private RenderFragment RenderControl(SettingDefinition setting) => builder =>
    {
        var index = 0;
        
        switch (setting.ControlType)
        {
            case SettingControlType.Toggle:
            case SettingControlType.Checkbox:
                builder.OpenElement(index++, "label");
                builder.AddAttribute(index++, "class", "toggle-switch");
                
                builder.OpenElement(index++, "input");
                builder.AddAttribute(index++, "type", "checkbox");
                builder.AddAttribute(index++, "id", setting.Key);
                builder.AddAttribute(index++, "checked", GetBoolValue(setting.Key));
                builder.AddAttribute(index++, "disabled", setting.IsReadOnly);
                builder.AddAttribute(index++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => OnValueChanged(setting.Key, e.Value)));
                builder.CloseElement();
                
                builder.OpenElement(index++, "span");
                builder.AddAttribute(index++, "class", "toggle-slider");
                builder.CloseElement();
                
                builder.CloseElement();
                break;
                
            case SettingControlType.Select:
                builder.OpenElement(index++, "select");
                builder.AddAttribute(index++, "id", setting.Key);
                builder.AddAttribute(index++, "class", "setting-select");
                builder.AddAttribute(index++, "disabled", setting.IsReadOnly);
                builder.AddAttribute(index++, "value", GetStringValue(setting.Key));
                builder.AddAttribute(index++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => OnValueChanged(setting.Key, e.Value)));
                
                if (setting.Options != null)
                {
                    foreach (var option in setting.Options)
                    {
                        builder.OpenElement(index++, "option");
                        builder.AddAttribute(index++, "value", option.Value);
                        builder.AddContent(index++, option.Label);
                        builder.CloseElement();
                    }
                }
                
                builder.CloseElement();
                break;
                
            case SettingControlType.Slider:
                builder.OpenElement(index++, "div");
                builder.AddAttribute(index++, "class", "slider-container");
                
                builder.OpenElement(index++, "input");
                builder.AddAttribute(index++, "type", "range");
                builder.AddAttribute(index++, "id", setting.Key);
                builder.AddAttribute(index++, "class", "setting-slider");
                builder.AddAttribute(index++, "min", setting.Min ?? 0);
                builder.AddAttribute(index++, "max", setting.Max ?? 100);
                builder.AddAttribute(index++, "step", setting.Step ?? 1);
                builder.AddAttribute(index++, "value", GetNumericValue(setting.Key));
                builder.AddAttribute(index++, "disabled", setting.IsReadOnly);
                builder.AddAttribute(index++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, e => OnValueChanged(setting.Key, e.Value)));
                builder.CloseElement();
                
                builder.OpenElement(index++, "span");
                builder.AddAttribute(index++, "class", "slider-value");
                builder.AddContent(index++, $"{GetNumericValue(setting.Key)} {setting.Unit ?? ""}");
                builder.CloseElement();
                
                builder.CloseElement();
                break;
                
            case SettingControlType.Number:
            case SettingControlType.Port:
                builder.OpenElement(index++, "div");
                builder.AddAttribute(index++, "class", "number-input-container");
                
                builder.OpenElement(index++, "input");
                builder.AddAttribute(index++, "type", "number");
                builder.AddAttribute(index++, "id", setting.Key);
                builder.AddAttribute(index++, "class", "setting-number");
                if (setting.Min.HasValue) builder.AddAttribute(index++, "min", setting.Min.Value);
                if (setting.Max.HasValue) builder.AddAttribute(index++, "max", setting.Max.Value);
                if (setting.Step.HasValue) builder.AddAttribute(index++, "step", setting.Step.Value);
                builder.AddAttribute(index++, "value", GetNumericValue(setting.Key));
                builder.AddAttribute(index++, "disabled", setting.IsReadOnly);
                builder.AddAttribute(index++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => OnValueChanged(setting.Key, e.Value)));
                builder.CloseElement();
                
                if (!string.IsNullOrEmpty(setting.Unit))
                {
                    builder.OpenElement(index++, "span");
                    builder.AddAttribute(index++, "class", "unit-label");
                    builder.AddContent(index++, setting.Unit);
                    builder.CloseElement();
                }
                
                builder.CloseElement();
                break;
                
            case SettingControlType.Url:
            case SettingControlType.IpAddress:
            case SettingControlType.Text:
            default:
                builder.OpenElement(index++, "input");
                builder.AddAttribute(index++, "type", setting.ControlType == SettingControlType.Url ? "url" : "text");
                builder.AddAttribute(index++, "id", setting.Key);
                builder.AddAttribute(index++, "class", "setting-text");
                builder.AddAttribute(index++, "value", GetStringValue(setting.Key));
                builder.AddAttribute(index++, "disabled", setting.IsReadOnly);
                if (!string.IsNullOrEmpty(setting.ValidationPattern))
                    builder.AddAttribute(index++, "pattern", setting.ValidationPattern);
                builder.AddAttribute(index++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, e => OnValueChanged(setting.Key, e.Value)));
                builder.CloseElement();
                break;
        }
    };
    
    private void OnValueChanged(string key, object? value)
    {
        _currentValues[key] = value;
        _hasChanges = _currentValues.Any(kv => 
            !Equals(kv.Value?.ToString(), _originalValues.GetValueOrDefault(kv.Key)?.ToString()));
        StateHasChanged();
    }
    
    private bool GetBoolValue(string key) => 
        _currentValues.TryGetValue(key, out var val) && val is true or "true" or "True";
    
    private string GetStringValue(string key) => 
        _currentValues.TryGetValue(key, out var val) ? val?.ToString() ?? "" : "";
    
    private double GetNumericValue(string key)
    {
        if (_currentValues.TryGetValue(key, out var val))
        {
            return val switch
            {
                int i => i,
                double d => d,
                string s when double.TryParse(s, out var parsed) => parsed,
                _ => 0
            };
        }
        return 0;
    }
    
    private bool IsChanged(string key) =>
        _currentValues.TryGetValue(key, out var current) &&
        _originalValues.TryGetValue(key, out var original) &&
        !Equals(current?.ToString(), original?.ToString());
    
    private string GetOriginalValue(string key) =>
        _originalValues.TryGetValue(key, out var val) ? val?.ToString() ?? "null" : "null";
    
    private int GetCategoryChangeCount(string category)
    {
        if (_settingsBundle == null) return 0;
        return _settingsBundle.GetByCategory(category).Count(s => IsChanged(s.Key));
    }
    
    private void ResetSetting(string key)
    {
        if (_originalValues.TryGetValue(key, out var original))
        {
            _currentValues[key] = original;
            _hasChanges = _currentValues.Any(kv => 
                !Equals(kv.Value?.ToString(), _originalValues.GetValueOrDefault(kv.Key)?.ToString()));
            StateHasChanged();
        }
    }
    
    private void ResetAllToDefaults()
    {
        if (_settingsBundle == null) return;
        
        foreach (var setting in _settingsBundle.Settings.Where(s => !s.IsReadOnly && s.DefaultValue != null))
        {
            _currentValues[setting.Key] = setting.DefaultValue;
        }
        
        _hasChanges = true;
        StateHasChanged();
    }
    
    private async Task SaveSettings()
    {
        if (_settingsBundle == null) return;
        
        foreach (var setting in _settingsBundle.Settings.Where(s => !s.IsReadOnly))
        {
            if (_currentValues.TryGetValue(setting.Key, out var value))
            {
                // Convert value to appropriate type
                object? typedValue = setting.DataType switch
                {
                    SettingDataType.Bool => value is true or "true" or "True",
                    SettingDataType.Int when int.TryParse(value?.ToString(), out var i) => i,
                    SettingDataType.Double when double.TryParse(value?.ToString(), out var d) => d,
                    _ => value?.ToString()
                };
                
                SettingsProvider.UpdateSetting(setting.Key, typedValue!);
                _originalValues[setting.Key] = value;
            }
        }
        
        _hasChanges = false;
        _showSaveConfirm = true;
        StateHasChanged();
        
        await Task.Delay(2000);
        _showSaveConfirm = false;
        StateHasChanged();
    }
    
    private async Task ExportSettings()
    {
        var json = SettingsProvider.ExportToJson();
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var base64 = Convert.ToBase64String(bytes);
        
        await JS.InvokeVoidAsync("eval", $@"
            const link = document.createElement('a');
            link.href = 'data:application/json;base64,{base64}';
            link.download = 'idiotproof-settings.json';
            link.click();
        ");
    }
    
    private static string GetCategoryIcon(string category) => category switch
    {
        "IB Connection" => "🔌",
        "Display" => "🖥️",
        "Web Integration" => "🌐",
        "Risk Management" => "⚠️",
        "Indicators" => "📊",
        "Timing" => "⏱️",
        _ => "⚙️"
    };
    
    private static string GetCategoryDescription(string category) => category switch
    {
        "IB Connection" => "Configure connection to Interactive Brokers TWS or Gateway",
        "Display" => "Customize how information is displayed",
        "Web Integration" => "Configure web frontend and API settings",
        "Risk Management" => "Control stop loss and risk parameters",
        "Indicators" => "Configure technical indicator settings",
        "Timing" => "Set intervals and timeouts",
        _ => ""
    };

    // Search functionality
    private void OnSearchChanged()
    {
        if (_settingsBundle == null) return;

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _filteredSettings = [];
        }
        else
        {
            var query = _searchQuery.ToLowerInvariant();
            _filteredSettings = _settingsBundle.Settings.Where(s =>
                s.DisplayName.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                s.Key.Contains(query, StringComparison.OrdinalIgnoreCase) ||
                (s.Description?.Contains(query, StringComparison.OrdinalIgnoreCase) ?? false) ||
                s.Category.Contains(query, StringComparison.OrdinalIgnoreCase));
        }
    }

    private void ClearSearch()
    {
        _searchQuery = "";
        _filteredSettings = [];
    }

    private MarkupString HighlightSearchTerm(string text)
    {
        if (string.IsNullOrWhiteSpace(_searchQuery) || string.IsNullOrEmpty(text))
            return new MarkupString(text);

        var index = text.IndexOf(_searchQuery, StringComparison.OrdinalIgnoreCase);
        if (index < 0) return new MarkupString(text);

        var before = text[..index];
        var match = text.Substring(index, _searchQuery.Length);
        var after = text[(index + _searchQuery.Length)..];

        return new MarkupString($"{before}<mark>{match}</mark>{after}");
    }

    // Import functionality
    private async Task ImportSettings(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;
            if (file.Size > 1024 * 100) // 100KB limit
            {
                return;
            }

            using var stream = file.OpenReadStream();
            using var reader = new System.IO.StreamReader(stream);
            var json = await reader.ReadToEndAsync();

            var importedBundle = JsonSerializer.Deserialize<SettingsBundle>(json);
            if (importedBundle?.Settings != null)
            {
                foreach (var imported in importedBundle.Settings)
                {
                    if (_settingsBundle?.Settings.Any(s => s.Key == imported.Key) == true)
                    {
                        _currentValues[imported.Key] = imported.Value;
                    }
                }

                _hasChanges = true;
                _importSuccess = true;
                _showSaveConfirm = true;
                StateHasChanged();

                await Task.Delay(2000);
                _showSaveConfirm = false;
                _importSuccess = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Import failed: {ex.Message}");
        }
    }
}
