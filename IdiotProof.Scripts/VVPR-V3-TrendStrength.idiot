#
# RISK: ADX at 22 - trend developing but not confirmed strong
# ============================================================================

Ticker(VVPR)
.Name("VVPR Trend Strength")
.Session(IS.EXTENDED)
.Qty(33)

# Breakout over VWAP
.Breakout(1.95)
.Pullback(1.80)

# Trend strength confirmation - lowered to 22 for current conditions
.IsAboveVwap()
.IsAdxAbove(22)
.IsDiPositive()

# Order execution
.Long()

# Mid-range target
.TakeProfit(2.15)
.StopLoss(1.62)
.TrailingStopLoss(5)

# Trailing stop for trend following
.TrailingStopLoss(4)

# Exit at bell if still open
.ExitStrategy(IS.BELL).IsProfitable()
