# ║       Bounce  Bounce  Entry                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# RISK: Low-Moderate - Mean reversion play with tight stop
# ============================================================================

Ticker(RUN)
.Name("RUN VWAP Bounce")
.Session(IS.RTH)
.Quantity(2)

# Pullback entry at VWAP test zone
.Pullback(20.50)

# Confirmation requirements
.IsCloseAboveVwap()
.IsHigherLows()
.IsEmaAbove(9)

# Order execution
.Order(IS.LONG)

# Risk management - target EMA resistance
.TakeProfit(20.95)
.StopLoss(20.25)
.TrailingStopLoss(2)
