# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# RISK: ADX weak - wait for trend to develop
# ============================================================================

Ticker(GDTC)
.Name("GDTC Momentum Stack")
.Session(IS.EXTENDED)
.Qty(57)

# Breakout over range resistance
.Breakout(1.25)
.Pullback(1.17)

# Momentum stack - lowered ADX threshold for weak trend
.IsAboveVwap()
.IsEmaAbove(21)
.IsMacdBullish()
.IsDiPositive()
.IsMomentumAbove(0)

# Order execution
.Long()
.Quantity(57)

# Extended target for momentum plays
.TakeProfit(1.50)
.StopLoss(1.05)

# Exit at bell if still open
.ExitStrategy(IS.BELL).IsProfitable()
