@inject StrategyRegistry StrategyRegistry

@if (Tab != null)
{
    <div class="strategy-list">
        @foreach (var binding in Tab.Strategies)
        {
            <div class="strategy-item @(binding.Enabled ? "" : "disabled")">
                <label>
                    <input type="checkbox" checked="@binding.Enabled"
                           @onchange="e => ToggleStrategy(binding, (bool)(e.Value ?? false))" />
                    @binding.StrategyName
                </label>
                <button class="btn-remove" @onclick="() => RemoveStrategy(binding)">X</button>
            </div>
        }

        <div class="strategy-add">
            <select @bind="_selectedStrategy">
                @foreach (var name in StrategyRegistry.GetNames())
                {
                    <option value="@name">@name</option>
                }
            </select>
            <button @onclick="AddStrategy">Add Strategy</button>
        </div>
    </div>
}

@code {
    [Parameter] public WorkspaceTab? Tab { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _selectedStrategy = "ITI";

    private async Task AddStrategy()
    {
        if (Tab == null) return;
        if (Tab.Strategies.Any(s => s.StrategyName == _selectedStrategy)) return;
        Tab.Strategies.Add(new StrategyBinding { StrategyName = _selectedStrategy });
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveStrategy(StrategyBinding binding)
    {
        if (Tab == null) return;
        Tab.Strategies.Remove(binding);
        await OnChanged.InvokeAsync();
    }

    private async Task ToggleStrategy(StrategyBinding binding, bool enabled)
    {
        binding.Enabled = enabled;
        await OnChanged.InvokeAsync();
    }
}
