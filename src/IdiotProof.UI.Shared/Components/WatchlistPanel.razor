@if (Tab != null)
{
    <div class="watchlist">
        @foreach (var symbol in Tab.Watchlist)
        {
            <div class="watchlist-item">
                <span>@symbol</span>
                <button class="btn-remove" @onclick="() => RemoveSymbol(symbol)">X</button>
            </div>
        }

        <div class="watchlist-add">
            <input @bind="_newSymbol" @bind:event="oninput" placeholder="Add symbol..."
                   @onkeydown="HandleKeyDown" />
            <button @onclick="AddSymbol">Add</button>
        </div>
    </div>
}

@code {
    [Parameter] public WorkspaceTab? Tab { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private string _newSymbol = "";

    private async Task AddSymbol()
    {
        if (Tab == null || string.IsNullOrWhiteSpace(_newSymbol)) return;
        var symbol = _newSymbol.Trim().ToUpperInvariant();
        if (!Tab.Watchlist.Contains(symbol))
        {
            Tab.Watchlist.Add(symbol);
            await OnChanged.InvokeAsync();
        }
        _newSymbol = "";
    }

    private async Task RemoveSymbol(string symbol)
    {
        if (Tab == null) return;
        Tab.Watchlist.Remove(symbol);
        await OnChanged.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddSymbol();
    }
}
