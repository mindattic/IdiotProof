@page "/"
@inject WorkspaceManager WorkspaceManager

<div class="dashboard">
    <TabBar ActiveTabId="@_activeTabId" OnTabSelected="SelectTab" />

    @if (_activeTab != null)
    {
        <WorkspaceView Tab="_activeTab" />
    }
</div>

@code {
    private string? _activeTabId;
    private WorkspaceTab? _activeTab;

    protected override void OnInitialized()
    {
        if (WorkspaceManager.Tabs.Count > 0)
        {
            SelectTab(WorkspaceManager.Tabs[0].TabId);
        }
    }

    private void SelectTab(string tabId)
    {
        _activeTabId = tabId;
        _activeTab = WorkspaceManager.Get(tabId);
    }
}
